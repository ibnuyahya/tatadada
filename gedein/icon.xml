<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>Gedein</app_name>
    <colors>
        <color_start>#FF9500</color_start>
        <color_end>#FF2D55</color_end>
    </colors>
    <background_style>
        <ornament>aurora</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.85</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Latar Belakang / Framing -->
        <circle cx="50" cy="50" r="42" class="frosted-glass" filter="url(#drop-shadow-sm)" />
        
        <!-- Objek Utama Volumetrik 3D: Lensa & Ekspansi Bingkai -->
        <g filter="url(#drop-shadow-sm)">
            <!-- Bingkai luar (Image placeholder yang melebar) -->
            <g filter="url(#inner-shadow)">
                <rect x="20" y="25" width="60" height="50" rx="12" fill="url(#glossy-white)" />
                <rect x="25" y="30" width="50" height="40" rx="8" fill="url(#glossy-dark)" />
            </g>
            
            <!-- Lensa Zoom di tengah -->
            <g filter="url(#inner-shadow)">
                <circle cx="50" cy="50" r="16" fill="url(#glossy-white)" opacity="0.9" />
                <circle cx="50" cy="50" r="12" fill="url(#glossy-dark)" />
                <!-- Pantulan Lensa (Aksen warna) -->
                <circle cx="50" cy="50" r="8" fill="#FF9500" />
                <circle cx="48" cy="48" r="3" fill="#FFFFFF" opacity="0.8" />
            </g>
            
            <!-- Sparkles/Bintang di sudut menandakan AI Magic -->
            <path d="M75,20 L77,25 L82,27 L77,29 L75,34 L73,29 L68,27 L73,25 Z" fill="#FF2D55" filter="url(#inner-shadow)"/>
        </g>
        
        <!-- Tipografi -->
        <text x="50" y="82" font-family="'Space Grotesk', sans-serif" font-weight="bold" font-size="11" fill="#FFFFFF" text-anchor="middle" filter="url(#drop-shadow-sm)">GEDEIN</text>
    </svg_elements>
    <visual_prompt>Filosofi komposisi memadukan lensa pembesar (mengisyaratkan detail/enlarge) dengan bingkai gambar yang terekspansi, merepresentasikan fungsi utama aplikasi. Paduan warna Oranye-Merah Muda memberikan kesan ajaib (AI Magic), dinamis, dan tidak membosankan seperti biru standar. Aksen resin gelap pada tengah bingkai memberikan kedalaman optik yang sangat kuat.</visual_prompt>
</icon_design>
