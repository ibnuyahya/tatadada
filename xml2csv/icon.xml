<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>XMLtoCSV</app_name>
    <colors>
        <color_start>#8E2DE2</color_start> <!-- Neon Purple -->
        <color_end>#4A00E0</color_end> <!-- Deep Indigo -->
    </colors>
    <background_style>
        <ornament>ios17_fluid_wave</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.82</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Latar Belakang / Framing (Paling Bawah) -->
        <circle cx="50" cy="50" r="42" class="frosted-glass" filter="url(#drop-shadow-sm)" />
        
        <!-- Objek Utama Volumetrik 3D: Mesin Transformasi Data -->
        <g filter="url(#drop-shadow-sm)">
            <!-- Bodi Utama Mesin Konverter (Resin Putih) -->
            <g filter="url(#inner-shadow)">
                <!-- Dokumen Mentah (Back) -->
                <rect x="25" y="20" width="40" height="48" rx="8" fill="url(#glossy-white)" opacity="0.6"/>
                <!-- Modul Data Utama (Front) -->
                <rect x="30" y="28" width="40" height="44" rx="8" fill="url(#glossy-white)" />
                
                <!-- Lensa / Rongga Proses Inti (Resin Gelap) -->
                <rect x="35" y="34" width="30" height="24" rx="4" fill="url(#glossy-dark)" />
                
                <!-- Aksen Data Berjalan (Warna Solid Kontras) -->
                <rect x="39" y="40" width="8" height="3" rx="1.5" fill="#32D74B" /> <!-- Hijau Apple -->
                <rect x="49" y="40" width="12" height="3" rx="1.5" fill="#FF9500" /> <!-- Oranye Apple -->
                
                <!-- Tabel Hasil CSV (Cyan Neon) -->
                <rect x="39" y="48" width="22" height="4" rx="2" fill="#00D2FF" />
            </g>
        </g>
        
        <!-- Ornamen Aksen Transformasi -->
        <g filter="url(#drop-shadow-sm)">
            <circle cx="50" cy="80" r="14" class="frosted-glass" />
            <!-- Simbol panah / konversi -->
            <path d="M47 76 L53 76 L50 84 Z" fill="#00D2FF" />
        </g>
        
        <!-- Tipografi (Paling Atas) -->
        <text x="50" y="84" font-family="'Space Grotesk', sans-serif" font-size="8" font-weight="bold" fill="#FFFFFF" text-anchor="middle" filter="url(#drop-shadow-sm)">CSV</text>
    </svg_elements>
    <visual_prompt>Filosofi desain ini berpusat pada "Data Core". Menggunakan kombinasi warna Deep Indigo dan Neon Purple untuk memberikan kesan pengolahan mesin (Engine) berkecepatan tinggi yang premium. Bodi berbentuk Resin Putih berlapis memberikan kedalaman 3D visual, sementara lensa gelap di tengah menampilkan proses perubahan dari data terpisah (Hijau/Oranye) menjadi struktur utuh (Cyan). Lingkaran frosted kecil di bawah mengokohkan estetika visionOS.</visual_prompt>
</icon_design>
