<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>Monopoliku Pro</app_name>
    <colors>
        <color_start>#F59E0B</color_start> <!-- Amber/Gold Rich -->
        <color_end>#0F172A</color_end> <!-- Slate Dark (Premium Board) -->
    </colors>
    <background_style>
        <ornament>ios17_fluid_wave</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.82</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Latar Belakang / Framing Board -->
        <rect x="15" y="15" width="70" height="70" rx="18" class="frosted-glass" filter="url(#drop-shadow-sm)" />
        
        <!-- Objek Utama Volumetrik 3D (Hotel Premium / Properti) -->
        <g filter="url(#drop-shadow-sm)">
            <!-- Badan Hotel Kaca Putih -->
            <path d="M 50 25 L 30 40 L 30 75 L 70 75 L 70 40 Z" fill="url(#glossy-white)" filter="url(#inner-shadow)" />
            <!-- Atap Emas Elegan -->
            <path d="M 50 20 L 25 40 L 75 40 Z" fill="#F59E0B" filter="url(#inner-shadow)" />
            <!-- Jendela (Resin Gelap untuk kesan Depth) -->
            <rect x="42" y="55" width="16" height="20" rx="4" fill="url(#glossy-dark)" filter="url(#inner-shadow)" />
            <!-- Aksen Dadu atau Tanda Kekayaan Merah Muda (Menyesuaikan ragam palet) -->
            <circle cx="50" cy="50" r="6" fill="#FF2D55" filter="url(#inner-shadow)" />
        </g>
        
        <!-- Tipografi (Paling Atas) -->
        <text x="50" y="88" font-family="'Righteous', cursive" font-size="11" fill="#FFFFFF" text-anchor="middle" filter="url(#drop-shadow-sm)">PROPERTI</text>
    </svg_elements>
    <visual_prompt>Komposisi ikon ini menyimbolkan 'Kekayaan Properti' lewat siluet Hotel/Real Estate dengan atap Emas murni yang megah (#F59E0B). Dasar cincinnya menggunakan Frosted Glass bergaya papan permainan. Rongga pintu jendela menggunakan glossy-dark agar terlihat sangat nyata dan dalam. Terdapat emblem/jewel warna merah muda solid (#FF2D55) di tengah sebagai sentuhan kontras khas palet dinamis yang mewah, melambangkan monopoli total. Keseluruhannya mematuhi Vibrant Depth ala iOS 17.</visual_prompt>
</icon_design>
