<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>BacaQR</app_name>
    <colors>
        <color_start>#10b981</color_start> <!-- Emerald Green -->
        <color_end>#14b8a6</color_end>   <!-- Teal -->
    </colors>
    <background_style>
        <ornament>ios17_fluid_wave</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.80</icon_scale>
    </proportions>
    <svg_elements>
        <!-- HANYA GEOMETRI PADAT BERVOLUME (NO STROKE) -->
        
        <!-- Base Scanner Block (Rounded Square) -->
        <rect x="15" y="15" width="70" height="70" rx="16" fill="url(#glossy-dark)" filter="url(#drop-shadow-sm)"/>
        
        <!-- Inner QR Grid Matrix (Melting Geometry approach) -->
        <g filter="url(#inner-shadow)">
            <!-- Top Left Finder Pattern -->
            <rect x="25" y="25" width="20" height="20" rx="6" fill="url(#glossy-white)"/>
            <rect x="30" y="30" width="10" height="10" rx="3" fill="var(--color-start)"/>
            
            <!-- Top Right Finder Pattern -->
            <rect x="55" y="25" width="20" height="20" rx="6" fill="url(#glossy-white)"/>
            <rect x="60" y="30" width="10" height="10" rx="3" fill="var(--color-start)"/>
            
            <!-- Bottom Left Finder Pattern -->
            <rect x="25" y="55" width="20" height="20" rx="6" fill="url(#glossy-white)"/>
            <rect x="30" y="60" width="10" height="10" rx="3" fill="var(--color-start)"/>
            
            <!-- Assorted Data Dots (Solid volumes simulating melting matrix) -->
            <circle cx="60" cy="60" r="5" fill="url(#glossy-white)"/>
            <circle cx="70" cy="60" r="5" fill="url(#glossy-white)"/>
            <circle cx="60" cy="70" r="5" fill="url(#glossy-white)"/>
            <rect x="50" y="50" width="10" height="10" rx="4" fill="url(#glossy-white)"/>
        </g>
        
        <!-- Floating Laser Line Indicator (Solid Volume Pill shape) -->
        <rect x="10" y="48" width="80" height="4" rx="2" fill="#34d399" filter="url(#drop-shadow-sm)"/>
    </svg_elements>
    <visual_prompt>Filosofi desainnya adalah merepresentasikan "Scanner Modern" menggunakan blok resin gelap yang solid dengan cetakan Finder Pattern putih mengkilap khas Apple di dalamnya. Pola QR-nya tidak tipis, melainkan geometri melingkar padat yang menyatu. Laser pemindai diwakili oleh sebuah pil berwarna hijau terang yang melayang di atas alas, menciptakan ilusi optik kedalaman (depth) tanpa menggunakan garis tipis sama sekali.</visual_prompt>
</icon_design>
