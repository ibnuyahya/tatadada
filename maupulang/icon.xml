<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>MauPulang</app_name>
    <colors>
        <color_start>#2E0B54</color_start>
        <color_end>#FF3B30</color_end>
    </colors>
    <background_style>
        <ornament>ios17_fluid_wave</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.82</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Latar Belakang / Framing -->
        <circle cx="50" cy="50" r="42" class="frosted-glass" filter="url(#drop-shadow-sm)" />
        
        <!-- Objek Utama: Portal Lorong Labirin 3D -->
        <g filter="url(#drop-shadow-sm)">
            <!-- Rongga Lorong (Resin Gelap) -->
            <g filter="url(#inner-shadow)">
                <rect x="20" y="20" width="60" height="60" rx="12" fill="url(#glossy-dark)" />
                <!-- Pola Lorong Labirin (Perspektif Abstrak) -->
                <path d="M20 20 L40 40 M80 20 L60 40 M20 80 L40 60 M80 80 L60 60" stroke="url(#glossy-white)" stroke-width="2" stroke-linecap="round" opacity="0.5" />
                <rect x="40" y="40" width="20" height="40" rx="4" fill="none" stroke="url(#glossy-white)" stroke-width="2" />
            </g>
            
            <!-- Cahaya Pintu Keluar (Resin Berwarna Kontras/Aksen) -->
            <g filter="url(#inner-shadow)">
                <rect x="42" y="42" width="16" height="38" rx="2" fill="#FF9500" />
                <circle cx="50" cy="55" r="4" fill="#FFFFFF" filter="url(#drop-shadow-sm)" />
            </g>
        </g>
        
        <!-- Tipografi -->
        <text x="50" y="78" font-family="'Space Grotesk', sans-serif" font-weight="bold" font-size="10" fill="#FFFFFF" text-anchor="middle" filter="url(#drop-shadow-sm)">HOME</text>
    </svg_elements>
    <visual_prompt>Filosofi desain: Ikon ini merepresentasikan konsep "Mau Pulang" (Mencari jalan pulang). Lorong labirin yang gelap dibentuk dengan kedalaman 3D menggunakan glossy-dark, memberikan kesan tersesat. Namun di ujungnya terdapat pintu bercahaya oranye neon (#FF9500) yang hangat, melambangkan rumah dan jalan keluar. Warna latar perpaduan ungu pekat ke merah memberikan nuansa misterius namun dinamis.</visual_prompt>
</icon_design>
