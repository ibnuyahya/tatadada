<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>mangbomber</app_name>
    <colors>
        <color_start>#f97316</color_start>
        <color_end>#9a3412</color_end>
    </colors>
    <background_style>
        <ornament>ios17_fluid_wave</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.80</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Layer 1: Bomb Shadow (Melting Geometry technique) -->
        <g filter="url(#drop-shadow-md)">
            <ellipse cx="50" cy="85" rx="35" ry="10" fill="#431407" opacity="0.6"/>
        </g>
        
        <!-- Layer 2: Main Solid Bomb Body (No stroke, full volume) -->
        <g filter="url(#inner-shadow)">
            <circle cx="50" cy="55" r="32" fill="#1e293b"/>
        </g>

        <!-- Layer 3: Bomb Glossy Highlight for 3D depth -->
        <path d="M 30 35 A 20 20 0 0 1 70 35 A 25 25 0 0 0 30 35 Z" fill="url(#glossy-white)" opacity="0.4"/>

        <!-- Layer 4: Metallic Bomb Cap -->
        <g filter="url(#inner-shadow)">
            <path d="M 40 25 L 60 25 L 56 32 L 44 32 Z" fill="#64748b"/>
        </g>

        <!-- Layer 5: Classic Fuse & Spark Volume (Solid shapes only, NO lines/strokes) -->
        <!-- The fuse body -->
        <path d="M 48 25 Q 40 10 55 5 Q 56 12 52 25 Z" fill="#94a3b8"/>
        
        <!-- Spark Core (Vibrant yellow-orange) -->
        <circle cx="58" cy="8" r="8" fill="#fbbf24" filter="url(#drop-shadow-sm)"/>
        
        <!-- Spark Details (Solid spiky geometric melt) -->
        <path d="M 58 0 L 60 5 L 66 2 L 63 7 L 69 9 L 63 11 L 65 17 L 60 14 L 56 19 L 55 13 L 49 14 L 53 10 L 48 6 L 54 6 Z" fill="#fef08a"/>
    </svg_elements>
    <visual_prompt>Geometri ikon memanifestasikan esensi klasik "Bomberman" ke dalam ekosistem Apple masa kini. Kami menggunakan kanvas fluid berwarna jingga vulkanik (ios17_fluid_wave) sebagai representasi ledakan kinetik. Bola bom dirangkai dari tumpukan lingkaran padat berwarna titanium gelap dengan lapisan pantulan glossy (Layer 3) guna menyuguhkan ilusi material resin sintesis. Tidak ada seutas garis (stroke) pun yang digunakan; sumbu dan percikan api dibentuk sepenuhnya menggunakan persimpangan "path" bervolume, mematuhi filosofi bentuk murni spasial yang tegas namun playful.</visual_prompt>
</icon_design>
