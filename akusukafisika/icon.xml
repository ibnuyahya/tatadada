<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>AkuSukaFisika</app_name>
    <colors>
        <color_start>#8B5CF6</color_start> <!-- Vibrant Violet -->
        <color_end>#06B6D4</color_end>   <!-- Cyan Energi -->
    </colors>
    <background_style>
        <ornament>aurora</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.82</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Latar Belakang / Framing (Paling Bawah) -->
        <circle cx="50" cy="50" r="42" class="frosted-glass" filter="url(#drop-shadow-sm)" />
        
        <!-- Objek Utama Volumetrik 3D: Inti Atom & Orbit -->
        <g filter="url(#drop-shadow-sm)">
            <g filter="url(#inner-shadow)">
                <!-- Cincin Orbit Terluar -->
                <ellipse cx="50" cy="50" rx="30" ry="12" fill="none" stroke="url(#glossy-white)" stroke-width="4" transform="rotate(30 50 50)" />
                <ellipse cx="50" cy="50" rx="30" ry="12" fill="none" stroke="url(#glossy-white)" stroke-width="4" transform="rotate(-30 50 50)" />
                <ellipse cx="50" cy="50" rx="30" ry="12" fill="none" stroke="url(#glossy-white)" stroke-width="4" transform="rotate(90 50 50)" />
                
                <!-- Inti Resin Gelap dengan Energi Solid -->
                <circle cx="50" cy="50" r="14" fill="url(#glossy-dark)" />
                <circle cx="50" cy="50" r="6" fill="#FDE047" /> <!-- Kuning Terang (Energi Pusat) -->
                
                <!-- Partikel / Elektron -->
                <circle cx="25" cy="35" r="4" fill="#06B6D4" />
                <circle cx="75" cy="65" r="4" fill="#8B5CF6" />
                <circle cx="50" cy="20" r="4" fill="#EC4899" />
            </g>
        </g>
        
        <!-- Tipografi (Paling Atas) -->
        <text x="50" y="82" font-family="'Space Grotesk', sans-serif" font-weight="bold" font-size="10" fill="#FFFFFF" text-anchor="middle" filter="url(#drop-shadow-sm)">PHYSICS</text>
    </svg_elements>
    <visual_prompt>Tafsir Visual: Ikon dirancang dengan estetika visionOS yang memadukan struktur frosted-glass dengan bentuk volumetrik. Ornamen aurora di latar belakang menyuntikkan nuansa fluks energi. Bagian tengah menggabungkan cincin orbit (hukum gerak Newton) dengan rongga resin gelap (mewakili kedalaman tekanan fluida Bernoulli/Pascal), dan inti energi berwarna cerah. Skema warna Violet dan Sian memberikan kesan futuristik yang jauh lebih menarik daripada gaya lab fisika konservatif.</visual_prompt>
</icon_design>
