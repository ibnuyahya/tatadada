<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>UkurDigital</app_name>
    <colors>
        <color_start>#5E5CE6</color_start>
        <color_end>#0A84FF</color_end>
    </colors>
    <background_style>
        <ornament>ios17_fluid_wave</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.80</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Layer 1: Framing Kaca (Paling Bawah) -->
        <rect x="15" y="15" width="70" height="70" rx="20" class="frosted-glass" filter="url(#drop-shadow-sm)" />

        <!-- Layer 2: Objek Utama (Ruler Amber & Caliper Jaw Putih) -->
        <g filter="url(#drop-shadow-sm)">
            <!-- Mistar/Objek Target Berwarna Amber/Oranye -->
            <rect x="25" y="40" width="50" height="20" rx="6" fill="#FF9500" filter="url(#inner-shadow)" />
            
            <!-- Tick marks pada mistar -->
            <line x1="30" y1="40" x2="30" y2="46" stroke="url(#glossy-dark)" stroke-width="2" />
            <line x1="40" y1="40" x2="40" y2="46" stroke="url(#glossy-dark)" stroke-width="2" />
            <line x1="50" y1="40" x2="50" y2="48" stroke="url(#glossy-dark)" stroke-width="2" />
            <line x1="60" y1="40" x2="60" y2="46" stroke="url(#glossy-dark)" stroke-width="2" />
            <line x1="70" y1="40" x2="70" y2="46" stroke="url(#glossy-dark)" stroke-width="2" />

            <!-- Rahang Caliper Solid Glossy White menumpang di atas mistar -->
            <path d="M 20 25 L 35 25 Q 40 25 40 30 L 40 70 Q 40 75 35 75 L 20 75 Z" fill="url(#glossy-white)" filter="url(#inner-shadow)" />
            
            <!-- Elemen resin gelap sebagai poros sekrup presisi -->
            <circle cx="30" cy="50" r="5" fill="url(#glossy-dark)" filter="url(#inner-shadow)" />
        </g>
    </svg_elements>
    <visual_prompt>Komposisi menempatkan bingkai kaca frosted sebagai latar pembatas, ditumpuk dengan blok objek mistar berwarna oranye solid yang sangat kontras (amber khas alat lab). Di atasnya, rahang caliper asimetris berbahan resin putih glossy mencengkeram mistar tersebut, dilengkapi sekrup resin gelap tebal di tengah. Ini melambangkan presisi sains ukur dengan estetika kedalaman volumetrik yang mantap dan dijamin tidak monoton.</visual_prompt>
</icon_design>
