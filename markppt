        <color_end>#FF2D55</color_end>
    </colors>
    <background_style>
        <ornament>ios17_fluid_wave</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.82</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Layer 1: Framing Kaca Frosted (Dasar) -->
        <rect x="15" y="20" width="70" height="60" rx="12" class="frosted-glass" filter="url(#drop-shadow-sm)" />
        
        <!-- Layer 2: Objek Utama Volumetrik (Presentasi / Layar) -->
        <g filter="url(#drop-shadow-sm)">
            <g filter="url(#inner-shadow)">
                <!-- Kertas Markdown (Belakang/Kiri) -->
                <rect x="20" y="25" width="40" height="50" rx="6" fill="url(#glossy-white)" opacity="0.9" transform="rotate(-5 40 50)" />
                <!-- Layar Presentasi (Depan/Kanan) -->
                <rect x="35" y="30" width="45" height="40" rx="8" fill="url(#glossy-dark)" />
            </g>
        </g>
        
        <!-- Layer 3: Aksen / Ornamen (Indikator Markdown ke PPT) -->
        <g filter="url(#drop-shadow-sm)">
            <g filter="url(#inner-shadow)">
                <!-- Panah Konversi (Tengah) -->
                <path d="M30 45 L40 45 L40 40 L50 50 L40 60 L40 55 L30 55 Z" fill="#FF9500" />
                <!-- Play Button PPT (Kanan) -->
                <polygon points="52,40 68,50 52,60" fill="#FF2D55" />
            </g>
        </g>
        
        <!-- Layer 4: Tipografi Apple-esque -->
        <text x="50" y="85" font-family="'Space Grotesk', sans-serif" font-weight="bold" font-size="11" fill="#FFFFFF" text-anchor="middle" filter="url(#drop-shadow-sm)">MD2PPT</text>
    </svg_elements>
    <visual_prompt>Komposisi menonjolkan proses transisi ("morphing") antara dokumen Markdown murni (bidang resin putih berotasi) menuju kanvas Presentasi (lensa layar resin gelap). Menggunakan palet Oranye-Ke-Merah Muda yang memberikan kesan kreatif, energetik, dan produktif, memecah stereotip aplikasi kantoran yang membosankan.</visual_prompt>
</icon_design>
