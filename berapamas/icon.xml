<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>BerapaMas</app_name>
    <colors>
        <color_start>#7C3AED</color_start> <!-- Violet -->
        <color_end>#DB2777</color_end> <!-- Pink -->
    </colors>
    <background_style>
        <ornament>ios17_fluid_wave</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.85</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Definisi Filter & Material (Glassmorphism & Volumetric) -->
        <defs>
            <filter id="drop-shadow-sm" x="-20%" y="-20%" width="140%" height="140%">
                <feDropShadow dx="0" dy="4" stdDeviation="6" flood-color="#000000" flood-opacity="0.15"/>
            </filter>
            
            <filter id="inner-shadow">
                <feOffset dx="0" dy="-2"/>
                <feGaussianBlur stdDeviation="2" result="offset-blur"/>
                <feComposite operator="out" in="SourceGraphic" in2="offset-blur" result="inverse"/>
                <feFlood flood-color="black" flood-opacity="0.25" result="color"/>
                <feComposite operator="in" in="color" in2="inverse" result="shadow"/>
                <feComposite operator="over" in="shadow" in2="SourceGraphic"/>
            </filter>

            <linearGradient id="glossy-white" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#ffffff" stop-opacity="1"/>
                <stop offset="100%" stop-color="#e2e8f0" stop-opacity="0.8"/>
            </linearGradient>

            <linearGradient id="glossy-dark" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#1e293b"/>
                <stop offset="100%" stop-color="#020617"/>
            </linearGradient>

            <linearGradient id="glossy-gold" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#FDE047"/>
                <stop offset="100%" stop-color="#D97706"/>
            </linearGradient>
        </defs>

        <!-- Layer 1: Latar Belakang / Framing (Paling Bawah) -->
        <circle cx="50" cy="50" r="42" fill="rgba(255, 255, 255, 0.2)" class="frosted-glass" filter="url(#drop-shadow-sm)" stroke="#ffffff" stroke-width="1.5" />
        
        <!-- Layer 2 & 3: Objek Utama Volumetrik 3D & Ornamen -->
        <g filter="url(#drop-shadow-sm)">
            
            <!-- Folder/Kotak Belakang (Warna Resin Gelap) -->
            <path d="M 28 42 L 72 42 L 72 68 C 72 70 70 72 68 72 L 32 72 C 30 72 28 70 28 68 Z" fill="url(#glossy-dark)" filter="url(#inner-shadow)" />

            <!-- Dokumen BRP (Masuk ke dalam kotak) -->
            <g transform="translate(0, -6)">
                <rect x="38" y="24" width="24" height="34" rx="3" fill="url(#glossy-white)" filter="url(#drop-shadow-sm)" />
                <!-- Garis Teks Dokumen -->
                <rect x="42" y="32" width="16" height="2" rx="1" fill="url(#glossy-dark)" opacity="0.3" />
                <rect x="42" y="38" width="10" height="2" rx="1" fill="url(#glossy-dark)" opacity="0.3" />
                <rect x="42" y="44" width="14" height="2" rx="1" fill="url(#glossy-dark)" opacity="0.3" />
                
                <!-- Aksen Ceklis Hijau (Tanda Validasi Ekstraksi) -->
                <circle cx="56" cy="48" r="4.5" fill="#10B981" filter="url(#inner-shadow)" />
                <path d="M 54.5 48 L 55.5 49.5 L 58 46" stroke="#ffffff" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round" />
            </g>

            <!-- Kotak Depan MBZ Zip (Warna Resin Emas) -->
            <path d="M 24 50 L 76 50 L 72 68 C 72 70 70 72 68 72 L 32 72 C 30 72 28 70 28 68 Z" fill="url(#glossy-gold)" filter="url(#inner-shadow)" />
            
            <!-- Label/Pita Kotak MBZ -->
            <rect x="42" y="55" width="16" height="8" rx="2" fill="url(#glossy-white)" filter="url(#inner-shadow)" />
            <rect x="45" y="58" width="10" height="2" rx="1" fill="#D97706" />
            
            <!-- Ornamen Sparkle Keemasan -->
            <circle cx="28" cy="32" r="3" fill="#FCD34D" filter="url(#inner-shadow)" />
            <circle cx="74" cy="36" r="2" fill="#FCD34D" filter="url(#inner-shadow)" />

        </g>
        
        <!-- Layer 4: Tipografi (Paling Atas) -->
        <text x="50" y="82" font-family="'Space Grotesk', sans-serif" font-weight="bold" font-size="9" letter-spacing="1" fill="#FFFFFF" text-anchor="middle" filter="url(#drop-shadow-sm)">BRP2MBZ</text>
    </svg_elements>
    <visual_prompt>Ikon 'BerapaMas' menggambarkan proses konversi dan kompresi ajaib. Sebuah dokumen BRP berwarna putih mengkilap (glossy-white) dengan lencana validasi hijau yang sempurna, meluncur masuk ke dalam wadah arsip MBZ volumetrik bernuansa emas (glossy-gold) dan ruang gelap (glossy-dark). Pemilihan palet latar belakang kontras Violet-ke-Pink memberikan sorotan magis dan modern ala visionOS, menegaskan kesan SANGAT PREMIUM tanpa elemen flat sama sekali.</visual_prompt>
</icon_design>
