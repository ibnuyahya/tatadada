<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>AcakIcik</app_name>
    <colors>
        <color_start>#0A84FF</color_start>
        <color_end>#5E5CE6</color_end>
    </colors>
    <background_style>
        <ornament>ios17_fluid_wave</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.80</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Latar Belakang / Framing (Paling Bawah) -->
        <circle cx="50" cy="50" r="42" class="frosted-glass" filter="url(#drop-shadow-sm)" />
        
        <!-- Objek Utama Volumetrik 3D: Perisai / Vault Keamanan -->
        <g filter="url(#drop-shadow-sm)">
            <!-- Tubuh Perisai Luar (Resin Putih) -->
            <path d="M50 15 L80 25 V45 C80 65 50 85 50 85 C50 85 20 65 20 45 V25 Z" fill="url(#glossy-white)" filter="url(#inner-shadow)" />
            
            <!-- Ruang Rongga Dalam (Resin Gelap) -->
            <path d="M50 23 L72 31 V46 C72 61 50 75 50 75 C50 75 28 61 28 46 V31 Z" fill="url(#glossy-dark)" filter="url(#inner-shadow)" />
            
            <!-- Inti Kode Terenkripsi (Aksen Neon) -->
            <rect x="42" y="38" width="16" height="4" rx="2" fill="#32D74B" filter="url(#inner-shadow)" />
            <rect x="38" y="46" width="24" height="4" rx="2" fill="#FF2D55" filter="url(#inner-shadow)" />
            <rect x="45" y="54" width="10" height="4" rx="2" fill="#FF9500" filter="url(#inner-shadow)" />
        </g>
        
        <!-- Tipografi (Paling Atas) -->
        <text x="50" y="78" font-family="'Space Grotesk', sans-serif" font-size="12" font-weight="bold" fill="#FFFFFF" text-anchor="middle" filter="url(#drop-shadow-sm)"></text>
    </svg_elements>
    <visual_prompt>Komposisi perisai 3D volumetrik mewakili perlindungan tingkat lanjut (Hybrid Web Protector). Berlapis resin putih glossy di bagian luar dan resin gelap berongga di dalam, menampung elemen neon yang merepresentasikan kode HTML/string yang diobfuscasi. Visual ini memberikan kesan keamanan siber yang mewah ala visionOS.</visual_prompt>
</icon_design>
