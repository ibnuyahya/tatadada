<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>AcakIcik</app_name>
    <colors>
        <color_start>#10B981</color_start>
        <color_end>#0F172A</color_end>
    </colors>
    <background_style>
        <ornament>ios17_fluid_wave</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.80</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Latar Belakang / Framing (Paling Bawah) -->
        <circle cx="50" cy="50" r="42" class="frosted-glass" filter="url(#drop-shadow-sm)" />
        
        <!-- Objek Utama Volumetrik 3D: Brankas Siber Tanpa Garis -->
        <g filter="url(#drop-shadow-sm)">
            <!-- Tubuh Brankas Luar -->
            <g filter="url(#inner-shadow)">
                <rect x="20" y="24" width="60" height="52" rx="14" fill="url(#glossy-white)" />
                <!-- Rongga Terdalam (Layar/Kubah) -->
                <rect x="28" y="32" width="44" height="36" rx="8" fill="url(#glossy-dark)" />
                
                <!-- Aksen Padat: Kode Batang Neon -->
                <rect x="36" y="42" width="28" height="4" rx="2" fill="#10B981" />
                <rect x="36" y="50" width="16" height="4" rx="2" fill="#3B82F6" />
                <rect x="56" y="50" width="8" height="4" rx="2" fill="#F59E0B" />
                
                <!-- Lampu Indikator Keamanan -->
                <circle cx="50" cy="28" r="2" fill="#EF4444" />
            </g>
        </g>
        
        <!-- Tipografi (Paling Atas) -->
        <text x="50" y="81" font-family="'Space Grotesk', sans-serif" font-size="11" font-weight="900" fill="#FFFFFF" text-anchor="middle" filter="url(#drop-shadow-sm)"></text>
    </svg_elements>
    <visual_prompt>Komposisi Brankas Siber menggunakan teknik Melting Geometry murni. Tubuh utama dipahat dari balok padat berbahan resin glossy putih, menjorok ke rongga resin gelap yang menampung balok-balok aksen neon solid (merpresentasikan baris kode). Desain tanpa stroke ini menciptakan kesan volumetrik 3D yang sangat kental dan premium.</visual_prompt>
</icon_design>
