<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>Excelin</app_name>
    <colors>
        <color_start>#34C759</color_start> <!-- Hijau Apple (Spreadsheet) -->
        <color_end>#30B0C7</color_end> <!-- Teal Laut Dalam (Ekspor Data) -->
    </colors>
    <background_style>
        <ornament>ios17_fluid_wave</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.85</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Latar Belakang / Framing (Paling Bawah) - Frosted Glass Base -->
        <rect x="10" y="10" width="80" height="80" rx="22" class="frosted-glass" filter="url(#drop-shadow-sm)" />
        
        <!-- Objek Utama Volumetrik 3D: Papan Tabel Pintar -->
        <g filter="url(#drop-shadow-sm)">
            <g filter="url(#inner-shadow)">
                <!-- Lembaran Kertas / Grid Belakang -->
                <rect x="25" y="20" width="50" height="60" rx="8" fill="url(#glossy-white)" />
                
                <!-- Sel Grid (Resin Gelap) -->
                <rect x="32" y="28" width="16" height="12" rx="3" fill="url(#glossy-dark)" />
                <rect x="52" y="28" width="16" height="12" rx="3" fill="url(#glossy-dark)" />
                <rect x="32" y="44" width="16" height="12" rx="3" fill="url(#glossy-dark)" />
                <rect x="52" y="44" width="16" height="12" rx="3" fill="url(#glossy-dark)" />
                
                <!-- Elemen Magis / Aksen Ekspor (Merah Muda & Emas agar tidak selalu biru/hijau) -->
                <circle cx="68" cy="62" r="14" fill="#FF2D55" filter="url(#inner-shadow)" />
                <path d="M64 62 L72 62 M68 58 L72 62 L68 66" stroke="#FFFFFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none" />
            </g>
        </g>
        
        <!-- Tipografi (Paling Atas) -->
        <text x="50" y="88" font-family="'Space Grotesk', sans-serif" font-weight="bold" font-size="10" fill="#FFFFFF" text-anchor="middle" filter="url(#drop-shadow-sm)">XLS</text>
    </svg_elements>
    <visual_prompt>Komposisi menonjolkan selembar 'tabel resin' berlapis kaca dengan rongga sel tabel di dalamnya. Di sudut bawah terdapat ornamen bulat merah muda mencolok (simbol ekstraksi/ekspor data seketika) yang memecah dominasi warna hijau-teal. Desain memadukan logika spreadsheet konvensional dengan sihir volumetrik khas visionOS.</visual_prompt>
</icon_design>
