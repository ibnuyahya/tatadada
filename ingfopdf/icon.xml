<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>IngfoPDF</app_name>
    <colors>
        <color_start>#30B0C7</color_start>
        <color_end>#34C759</color_end>
    </colors>
    <background_style>
        <ornament>aurora</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.82</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Latar Belakang / Framing (Paling Bawah) -->
        <circle cx="50" cy="50" r="42" class="frosted-glass" filter="url(#drop-shadow-sm)" />
        
        <!-- Objek Utama Volumetrik 3D: Shield Dokumen -->
        <g filter="url(#drop-shadow-sm)">
            <g filter="url(#inner-shadow)">
                <!-- Lembaran Dokumen -->
                <rect x="28" y="20" width="44" height="54" rx="8" fill="url(#glossy-white)" />
                <!-- Lipatan Kertas Kanan Atas -->
                <path d="M 58 20 L 72 34 L 58 34 Z" fill="#E2E8F0" filter="url(#inner-shadow)"/>
                
                <!-- Lensa Pemindai Forensik (Resin Gelap) -->
                <circle cx="50" cy="52" r="16" fill="url(#glossy-dark)" />
                
                <!-- Aksen Radar / Laser Pemindai -->
                <circle cx="50" cy="52" r="6" fill="#FF9500" filter="url(#inner-shadow)" />
                <path d="M 34 52 L 66 52" stroke="#FF9500" stroke-width="1.5" opacity="0.8" />
            </g>
        </g>
        
        <!-- Tipografi (Paling Atas) -->
        <text x="50" y="82" font-family="'Space Grotesk', sans-serif" font-size="11" font-weight="bold" fill="#FFFFFF" text-anchor="middle" filter="url(#drop-shadow-sm)">PDF Forensic</text>
    </svg_elements>
    <visual_prompt>Ikon IngfoPDF mengusung tema 'Verification Scanner' dengan estetika visionOS. Latar belakang menggunakan ornamen aurora bergradasi Teal ke Emerald yang melambangkan validitas dan keamanan. Di atasnya terdapat lembaran dokumen volumetrik berbahan resin glossy putih, dengan rongga lensa gelap (glossy-dark) di tengahnya yang memancarkan aksen radar oranye cerah, melambangkan 'Mata Forensik' yang sedang memindai metadata PDF tersembunyi. Penggunaan palet Teal-Emerald-Orange memberikan kontras yang sangat beragam dan segar, menjauh dari biru korporat standar.</visual_prompt>
</icon_design>
