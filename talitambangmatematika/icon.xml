<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>Tarik Tali Matematika</app_name>
    <colors>
        <color_start>#FF9500</color_start>
        <color_end>#FF3B30</color_end>
    </colors>
    <background_style>
        <ornament>ios17_fluid_wave</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.75</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Arena Kaca Frosted Besar yang membingkai komposisi -->
        <circle cx="50" cy="50" r="42" class="frosted-glass" filter="url(#drop-shadow-sm)" />
        
        <!-- Tali Penghubung Utama yang Chunky -->
        <rect x="8" y="44" width="84" height="12" rx="6" fill="url(#glossy-white)" filter="url(#inner-shadow)" />
        
        <!-- Sisi Kiri: Geometri Vertikal memotong tali membentuk Tanda Tambah (+) -->
        <rect x="22" y="28" width="12" height="44" rx="6" fill="url(#glossy-white)" filter="url(#drop-shadow-sm)" />
        
        <!-- Sisi Kanan: Dua Lingkaran mengapit tali membentuk Tanda Bagi (÷) -->
        <circle cx="72" cy="28" r="8" fill="url(#glossy-white)" filter="url(#drop-shadow-sm)" />
        <circle cx="72" cy="72" r="8" fill="url(#glossy-white)" filter="url(#drop-shadow-sm)" />
        
        <!-- Simpul Tengah (Knot) Pengikat Tali dengan lubang kaca -->
        <rect x="38" y="38" width="24" height="24" rx="8" fill="url(#glossy-white)" filter="url(#drop-shadow-sm)" />
        <circle cx="50" cy="50" r="6" class="frosted-glass" filter="url(#inner-shadow)" />
    </svg_elements>
    <visual_prompt>Cincin kaca frosted raksasa membingkai elemen solid secara terpusat, mengoptimalkan negative space. Geometri dirancang sangat stabil dan chunky: Tali horizontal membelah area, berinteraksi dengan garis vertikal di kiri membentuk (+) dan dua titik di kanan membentuk (÷). Simpul sentral berongga mengunci seluruh komposisi, menegaskan estetika glassmorphism dan volume solid yang khas pada ikon iOS 17.</visual_prompt>
</icon_design>
