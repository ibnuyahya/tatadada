<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>TabelCuan</app_name>
    <colors>
        <color_start>#10b981</color_start> <!-- Emerald Green for Profit -->
        <color_end>#0f766e</color_end>     <!-- Deep Teal for Depth -->
    </colors>
    <background_style>
        <ornament>ios17_fluid_wave</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.80</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Layer 1: Framing (Base Spreadsheet Card) -->
        <rect x="20" y="25" width="60" height="50" rx="8" fill="url(#glossy-dark)" opacity="0.9" filter="url(#drop-shadow-sm)"/>
        
        <!-- Layer 2: Grid Lines (Spreadsheet look) -->
        <path d="M20 40 H80 M40 25 V75 M60 25 V75" stroke="#ffffff" stroke-width="2" stroke-opacity="0.15" fill="none"/>
        
        <!-- Layer 3: Main Object (Upward Trend Line / Cuan) -->
        <path d="M25 65 L45 45 L55 50 L75 20" stroke="#fbbf24" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" fill="none" filter="url(#drop-shadow-sm)"/>
        
        <!-- Layer 4: Accents (Sparkles/Dots at data points) -->
        <circle cx="45" cy="45" r="3" fill="#ffffff" filter="url(#inner-shadow)"/>
        <circle cx="55" cy="50" r="3" fill="#ffffff" filter="url(#inner-shadow)"/>
        <circle cx="75" cy="20" r="4" fill="#fbbf24" filter="url(#inner-shadow)"/>
    </svg_elements>
    <visual_prompt>Ikon premium berdimensi merepresentasikan spreadsheet (Tabel) transparan bergaya frosted-glass dengan garis tren emas menanjak (Cuan/Profit), menonjolkan kesan profesional untuk alat finansial/analisis.</visual_prompt>
</icon_design>
