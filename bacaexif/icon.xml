<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>BacaEXIF</app_name>
    <colors>
        <color_start>#0A84FF</color_start>
        <color_end>#5E5CE6</color_end>
    </colors>
    <background_style>
        <ornament>aurora</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.82</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Latar Belakang / Framing (Paling Bawah) -->
        <rect x="10" y="10" width="80" height="80" rx="22" class="frosted-glass" filter="url(#drop-shadow-sm)" />
        
        <!-- Objek Utama Volumetrik 3D -->
        <g filter="url(#drop-shadow-sm)">
            <!-- Bodi Kamera Netral -->
            <g filter="url(#inner-shadow)">
                <rect x="20" y="22" width="60" height="42" rx="10" fill="url(#glossy-white)" />
                <!-- Tombol Shutter / Aksen -->
                <rect x="26" y="18" width="12" height="6" rx="3" fill="#FF2D55" />
                <circle cx="70" cy="30" r="3.5" fill="#FF9500" />
            </g>
            <!-- Lensa Kamera Premium -->
            <g filter="url(#inner-shadow)">
                <circle cx="50" cy="43" r="18" fill="url(#glossy-white)" />
                <circle cx="50" cy="43" r="14" fill="url(#glossy-dark)" />
                <!-- Inti Lensa / Data Iris -->
                <circle cx="50" cy="43" r="6" fill="#32ADE6" />
                <!-- Refleksi Kaca -->
                <circle cx="47" cy="40" r="2.5" fill="#FFFFFF" opacity="0.8" />
            </g>
        </g>
        
        <!-- Tipografi (Paling Atas) -->
        <text x="50" y="86" font-family="'Space Grotesk', sans-serif" font-weight="700" font-size="13" fill="#FFFFFF" text-anchor="middle" filter="url(#drop-shadow-sm)">EXIF</text>
    </svg_elements>
    <visual_prompt>Desain ikon mewakili 'Inspeksi Meta-Data'. Menggunakan siluet kamera volumetrik berlapis (glossy-white) dengan rongga lensa dalam (glossy-dark) yang memancarkan inti data berwarna biru cyan. Latar belakang aurora iOS dipadukan material frosted-glass memberikan kesan premium visionOS.</visual_prompt>
</icon_design>
