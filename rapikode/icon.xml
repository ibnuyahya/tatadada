<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>Rapikode</app_name>
    <colors>
        <color_start>#8B5CF6</color_start> <!-- Violet -->
        <color_end>#3B82F6</color_end> <!-- Biru Terang -->
    </colors>
    <background_style>
        <ornament>ios17_fluid_wave</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.82</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Latar Belakang / Framing (Paling Bawah) -->
        <circle cx="50" cy="50" r="42" class="frosted-glass" filter="url(#drop-shadow-sm)" />
        
        <!-- Objek Utama Volumetrik 3D: Cincin Scoping / Kurawal Maya -->
        <g filter="url(#drop-shadow-sm)">
            <g filter="url(#inner-shadow)">
                <!-- Base Dark Resin: Representasi Editor Code / Terminal -->
                <rect x="22" y="22" width="56" height="56" rx="14" fill="url(#glossy-dark)" />
                
                <!-- Tumpukan Bar (Tidy Code Representation) -->
                <!-- Bar 1: Tidak ter-indent -->
                <rect x="30" y="32" width="40" height="6" rx="3" fill="url(#glossy-white)" />
                <!-- Bar 2: Ter-indent (Smart Scoping) -->
                <rect x="40" y="44" width="30" height="6" rx="3" fill="#F59E0B" /> <!-- Aksen Kuning Amber/Warning/Smart -->
                <!-- Bar 3: Ter-indent dalam -->
                <rect x="50" y="56" width="20" height="6" rx="3" fill="#10B981" /> <!-- Aksen Hijau Emerald/Success -->
                <!-- Bar 4: Menutup scope -->
                <rect x="30" y="68" width="25" height="6" rx="3" fill="url(#glossy-white)" />
            </g>
        </g>
    </svg_elements>
    <visual_prompt>Filosofi desain: Sebuah terminal gelap (glossy-dark) yang di dalamnya terdapat blok-blok kode bercahaya (glossy-white, amber, emerald) yang sedang disusun secara otomatis membentuk struktur indentasi piramida. Penggunaan palet latar belakang Violet ke Biru mencerminkan kecerdasan buatan, logika, dan kebersihan sistem iOS. Kedalaman visual diperkuat oleh cincin frosted-glass di luar editor.</visual_prompt>
</icon_design>
