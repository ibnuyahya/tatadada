<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>IconXstudio</app_name>
    <colors>
        <color_start>#4B0082</color_start>
        <color_end>#FF4500</color_end>
    </colors>
    <background_style>
        <ornament>ios17_fluid_wave</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.80</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Layer 1: Framing (Solid Frosted Base - Bebas Stroke) -->
        <rect x="15" y="15" width="70" height="70" rx="18" class="frosted-glass" filter="url(#drop-shadow-sm)" />
        
        <!-- Layer 2: Objek Utama (Melting Geometry) -->
        <g filter="url(#drop-shadow-sm)">
            <g filter="url(#inner-shadow)">
                <circle cx="50" cy="50" r="28" fill="url(#glossy-dark)" />
                <rect x="25" y="44" width="50" height="12" rx="6" transform="rotate(45 50 50)" fill="url(#glossy-white)" />
                <rect x="25" y="44" width="50" height="12" rx="6" transform="rotate(-45 50 50)" fill="url(#glossy-white)" />
                <circle cx="50" cy="50" r="10" fill="#00FFCC" />
            </g>
        </g>
        
        <!-- Layer 3: Aksen Volumetrik -->
        <g filter="url(#drop-shadow-sm)">
            <circle cx="25" cy="25" r="4" fill="#FF2D55" filter="url(#inner-shadow)" />
            <circle cx="75" cy="75" r="5" fill="#FFCC00" filter="url(#inner-shadow)" />
        </g>
        
        <!-- Layer 4: Tipografi -->
        <text x="50" y="82" font-family="'Space Grotesk', sans-serif" font-weight="700" font-size="9" fill="#FFFFFF" text-anchor="middle" letter-spacing="1.5" filter="url(#drop-shadow-sm)">ICONX</text>
    </svg_elements>
    <visual_prompt>Desain ikon IconXstudio dibangun menggunakan prinsip 'Melting Geometry' bebas-garis (stroke-free). Pilar huruf X melebur sempurna dengan dasar lingkaran gelap berkat filter inner-shadow, menciptakan cetakan resin 3D volumetrik. Inti energi cyan memberikan kontras tajam melawan tema ungu-oranye.</visual_prompt>
</icon_design>
