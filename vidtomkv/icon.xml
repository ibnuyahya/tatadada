<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>MKVtoMP4</app_name>
    <colors>
        <color_start>#8B5CF6</color_start>
        <color_end>#EC4899</color_end>
    </colors>
    <background_style>
        <ornament>ios17_fluid_wave</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.85</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Latar Belakang / Framing (Paling Bawah) -->
        <circle cx="50" cy="50" r="42" class="frosted-glass" filter="url(#drop-shadow-sm)" />
        
        <!-- Objek Utama Volumetrik 3D -->
        <g filter="url(#drop-shadow-sm)">
            <g filter="url(#inner-shadow)">
                <!-- Cakram Film Luar (Wadah Asli) -->
                <circle cx="45" cy="45" r="24" fill="url(#glossy-white)" />
                <circle cx="45" cy="45" r="10" fill="url(#glossy-dark)" />
                
                <!-- Cakram Konversi (Wadah Baru MP4) -->
                <circle cx="58" cy="58" r="18" fill="#EC4899" />
                <circle cx="58" cy="58" r="6" fill="url(#glossy-dark)" />
                
                <!-- Petir (Kecepatan Stream Copy) -->
                <path d="M48 38 L55 38 L51 48 L58 48 L46 60 L50 48 L43 48 Z" fill="#FBBF24" filter="url(#drop-shadow-sm)"/>
            </g>
        </g>
        
        <!-- Tipografi (Paling Atas) -->
        <text x="50" y="82" font-family="'Space Grotesk', sans-serif" font-weight="bold" font-size="11" fill="#FFFFFF" text-anchor="middle" filter="url(#drop-shadow-sm)">VID 2 MKV</text>
    </svg_elements>
    <visual_prompt>Filosofi desain memadukan elemen sinematik (cakram spul film) yang bertransformasi. Cakram resin putih melambangkan wadah MKV sumber, sedangkan cakram magenta cerah melambangkan wadah MP4 yang modern. Aksen petir emas solid menegaskan fungsi 'Stream Copy' yang super cepat. Menggunakan material resin tebal dan kaca frosted untuk gaya dimensi visionOS yang premium dengan kedalaman visual tinggi.</visual_prompt>
</icon_design>
