<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>CekCuan</app_name>
    <colors>
        <color_start>#10B981</color_start> <!-- Emerald Green / Profit -->
        <color_end>#F59E0B</color_end> <!-- Amber Gold / Wealth -->
    </colors>
    <background_style>
        <ornament>ios17_fluid_wave</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.85</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Latar Belakang / Framing (Paling Bawah) -->
        <circle cx="50" cy="50" r="42" class="frosted-glass" filter="url(#drop-shadow-sm)" />
        
        <!-- Objek Utama Volumetrik 3D -->
        <g filter="url(#drop-shadow-sm)">
            <g filter="url(#inner-shadow)">
                <!-- Cangkang Analitik -->
                <rect x="18" y="22" width="64" height="46" rx="12" fill="url(#glossy-white)" />
                <!-- Layar / Dashboard Dalam -->
                <rect x="23" y="27" width="54" height="36" rx="6" fill="url(#glossy-dark)" />
                <!-- Grafik PnL (Emerald) -->
                <path d="M 28 55 L 35 42 L 45 48 L 58 32 L 68 32 L 68 55 Z" fill="#10B981" filter="url(#drop-shadow-sm)" />
                <!-- Titik Target/Puncak (Amber) -->
                <circle cx="58" cy="32" r="5" fill="#F59E0B" />
            </g>
        </g>
        
        <!-- Tipografi (Paling Atas) -->
        <text x="50" y="82" font-family="'Space Grotesk', sans-serif" font-weight="bold" font-size="11" fill="#FFFFFF" text-anchor="middle" filter="url(#drop-shadow-sm)">CEKCUAN</text>
    </svg_elements>
    <visual_prompt>Ikon "CekCuan" dirancang menggunakan metafora "Mesin Analitik Finansial". Memadukan warna Emerald (keuntungan) dan Amber/Gold (kekayaan) untuk keluar dari bias warna biru standar iOS. Objek 3D berupa cangkang glossy putih yang membingkai layar glossy gelap (dashboard analyzer), ditemani grafik pertumbuhan menanjak yang elegan. Desain ini merepresentasikan kedalaman data dan keamanan finansial.</visual_prompt>
</icon_design>
