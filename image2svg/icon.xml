<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>Smart Tracer</app_name>
    <colors>
        <color_start>#4F46E5</color_start>
        <color_end>#8B5CF6</color_end>
    </colors>
    <background_style>
        <ornament>ios17_fluid_wave</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.80</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Layer 1: Base Canvas / Frame (Solid Volume) -->
        <rect x="20" y="20" width="60" height="60" rx="16" fill="#1E1B4B" filter="url(#drop-shadow-sm)"/>
        
        <!-- Layer 2: Pen Tool / Vector Node Representation -->
        <g filter="url(#inner-shadow)">
            <circle cx="50" cy="35" r="14" fill="url(#glossy-white)"/>
            <path d="M40,65 L50,45 L60,65 Z" fill="#6D28D9"/>
            <!-- Abstract floating nodes indicating tracing points -->
            <circle cx="35" cy="55" r="4" fill="#38BDF8"/>
            <circle cx="65" cy="55" r="4" fill="#38BDF8"/>
        </g>
        
        <!-- Layer 3: Accent - Smart Sparkle -->
        <path d="M70,25 Q75,25 75,20 Q75,25 80,25 Q75,25 75,30 Q75,25 70,25 Z" fill="#FDE047"/>
    </svg_elements>
    <visual_prompt>Desain ini menggabungkan metafora "Pen Tool" (ujung panah dan titik jangkar/nodes) dengan "Lensa/Mata Pintar" (lingkaran putih mengkilap). Efek melting geometry pada persinggungan bentuk menciptakan kesan bahwa piksel raster sedang dilebur menjadi vektor mulus yang padat dan tajam.</visual_prompt>
</icon_design>
