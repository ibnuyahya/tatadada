<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>AlatWasap</app_name>
    <colors>
        <color_start>#25D366</color_start> <!-- WhatsApp Green -->
        <color_end>#0C8B74</color_end>   <!-- Deep Emerald -->
    </colors>
    <background_style>
        <ornament>ios17_fluid_wave</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.85</icon_scale>
    </proportions>
    <svg_elements>
        <!-- LAYER 1: Shadow Gelembung Chat -->
        <path d="M 25 20 L 75 20 C 85 20 90 25 90 35 L 90 65 C 90 75 85 80 75 80 L 35 80 L 15 95 L 15 80 C 12 80 10 78 10 65 L 10 35 C 10 25 15 20 25 20 Z" fill="#000000" opacity="0.15" filter="url(#drop-shadow-sm)" transform="translate(4, 6)"/>
        
        <!-- LAYER 2: Gelembung Chat Utama (Vibrant Depth) -->
        <path d="M 25 20 L 75 20 C 85 20 90 25 90 35 L 90 65 C 90 75 85 80 75 80 L 35 80 L 15 95 L 15 80 C 12 80 10 78 10 65 L 10 35 C 10 25 15 20 25 20 Z" fill="url(#glossy-white)" filter="url(#inner-shadow)"/>
        <path d="M 25 20 L 75 20 C 85 20 90 25 90 35 L 90 65 C 90 75 85 80 75 80 L 35 80 L 15 95 L 15 80 C 12 80 10 78 10 65 L 10 35 C 10 25 15 20 25 20 Z" fill="url(#main-gradient)" opacity="0.95"/>
        
        <!-- LAYER 3: Kertas Template (Transparan di dalam gelembung) -->
        <!-- Melambangkan Editor HTML dan Manajer Template -->
        <rect x="25" y="28" width="45" height="35" rx="4" fill="#ffffff" opacity="0.25" transform="rotate(-8 45 45)" />
        <rect x="30" y="35" width="45" height="35" rx="4" fill="#ffffff" opacity="0.4" transform="rotate(5 45 45)" />
        
        <!-- LAYER 4: Pesawat Kertas 3D Origami (Direct Chat) -->
        <!-- Bayangan Pesawat -->
        <polygon points="25,48 80,22 55,75" fill="#000000" opacity="0.15" filter="url(#drop-shadow-sm)" transform="translate(2, 4)"/>
        <!-- Sayap Kiri (Terang) -->
        <polygon points="25,45 80,25 45,55" fill="#ffffff" filter="url(#drop-shadow-sm)"/>
        <!-- Sayap Kanan (Agak Gelap untuk Dimensi 3D) -->
        <polygon points="45,55 80,25 55,75" fill="#e2e8f0" />
        <!-- Lipatan Bawah Pesawat (Gelap) -->
        <polygon points="45,55 45,70 55,75" fill="#cbd5e1" />
        
        <!-- Aksen Kilauan (Utilitas/Magic/Smart Tool) -->
        <circle cx="80" cy="20" r="4" fill="#ffffff" filter="url(#drop-shadow-sm)"/>
        <circle cx="20" cy="35" r="2.5" fill="#ffffff" opacity="0.8"/>
    </svg_elements>
    <visual_prompt>Desain ini mencerminkan evolusi "AlatWasap". Berbasis pada bentuk organik gelembung WhatsApp khas iOS 17 dengan "Vibrant Depth" hijau, ikon ini kini disematkan "Pesawat Kertas 3D" bervolume padat yang menembus keluar. Pesawat ini mewakili fitur "Direct Chat" (kirim cepat tanpa save nomor). Di belakang pesawat, terdapat tumpukan persegi semi-kaca yang melambangkan fitur penyimpan "Draf/Template" dan konversi "Dokumen (HTML)". Semuanya digambar menggunakan geometri padat (Z-Index layer 3D) tanpa garis tipis.</visual_prompt>
</icon_design>
