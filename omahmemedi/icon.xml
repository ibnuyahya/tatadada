<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>OmahMemedi</app_name>
    <colors>
        <color_start>#5e0000</color_start>
        <color_end>#0a0a0a</color_end>
    </colors>
    <background_style>
        <ornament>aurora</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.80</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Background Glow -->
        <circle cx="50" cy="50" r="40" fill="url(#glossy-dark)" filter="url(#drop-shadow-sm)"/>
        
        <!-- Old Haunted House Silhouette -->
        <path d="M20,60 L20,40 L50,15 L80,40 L80,60 Z" fill="#111111" stroke="#ff0000" stroke-width="2" filter="url(#inner-shadow)"/>
        <path d="M35,60 L35,45 L45,45 L45,60 Z" fill="#ff0000" class="frosted-glass"/>
        <path d="M55,60 L55,45 L65,45 L65,60 Z" fill="#ff0000" class="frosted-glass"/>
        
        <!-- Creepy Spider Web Accent -->
        <path d="M20,40 Q35,50 50,15" stroke="#ffffff" stroke-width="0.5" fill="none" opacity="0.3"/>
        <path d="M80,40 Q65,50 50,15" stroke="#ffffff" stroke-width="0.5" fill="none" opacity="0.3"/>

        <!-- Ghostly Eyes -->
        <circle cx="40" cy="52" r="1.5" fill="#ffffff" filter="url(#drop-shadow-sm)"/>
        <circle cx="60" cy="52" r="1.5" fill="#ffffff" filter="url(#drop-shadow-sm)"/>
    </svg_elements>
    <visual_prompt>Ikon berdimensi dengan siluet rumah tua (Omah Memedi) bergaya low-poly. Jendelanya memancarkan cahaya merah darah (frosted glass) yang menembus kegelapan malam, dilengkapi dengan dua pasang mata hantu kecil yang mengintip. Skema warna merah tua ke hitam pekat memberikan aura kengerian dan misteri.</visual_prompt>
</icon_design>
