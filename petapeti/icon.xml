<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>petapeti</app_name>
    <colors>
        <color_start>#FF2D55</color_start> <!-- Merah Keras (Gempa/Magma) -->
        <color_end>#5AC8FA</color_end>   <!-- Biru Cerah (Atmosfer/Cuaca) -->
    </colors>
    <background_style>
        <ornament>ios17_fluid_wave</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.82</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Latar Belakang / Framing (Paling Bawah) -->
        <circle cx="50" cy="50" r="42" class="frosted-glass" filter="url(#drop-shadow-sm)" />
        
        <!-- Objek Utama Volumetrik 3D (Radar/Globe Hibrida) -->
        <g filter="url(#drop-shadow-sm)">
            <!-- Piringan Radar Glossy -->
            <g filter="url(#inner-shadow)">
                <circle cx="50" cy="50" r="30" fill="url(#glossy-white)" />
                <circle cx="50" cy="50" r="22" fill="url(#glossy-dark)" />
                
                <!-- Elemen Gelombang Radar / Episentrum -->
                <path d="M50 28 A22 22 0 0 1 72 50" fill="none" stroke="#5AC8FA" stroke-width="3" stroke-linecap="round" />
                <path d="M50 35 A15 15 0 0 1 65 50" fill="none" stroke="#FF9500" stroke-width="2" stroke-linecap="round" />
                
                <!-- Titik Magma/Gempa Inti -->
                <circle cx="50" cy="50" r="6" fill="#FF2D55" filter="url(#inner-shadow)" />
                <circle cx="50" cy="50" r="2" fill="#FFFFFF" />
            </g>
        </g>
        
        <!-- Tipografi (Paling Atas) -->
        <text x="50" y="80" font-family="'Space Grotesk', sans-serif" font-weight="bold" font-size="10" fill="#FFFFFF" text-anchor="middle" filter="url(#drop-shadow-sm)" letter-spacing="1">LIVE</text>
    </svg_elements>
    <visual_prompt>[Konsep memadukan lensa radar (cuaca) dan episentrum merah/oranye (bencana) di atas piringan resin putih. Penggunaan warna #FF2D55 dan #5AC8FA menciptakan kontras suhu (panas bumi vs atmosfer dingin) yang merepresentasikan fungsi monitoring aplikasi secara menyeluruh dan elegan.]</visual_prompt>
</icon_design>
