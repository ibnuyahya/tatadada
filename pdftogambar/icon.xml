<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>PDFtoGambar</app_name>
    <colors>
        <color_start>#FF2D55</color_start>
        <color_end>#FF9500</color_end>
    </colors>
    <background_style>
        <ornament>ios17_fluid_wave</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.82</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Latar Belakang / Framing (Paling Bawah) -->
        <circle cx="50" cy="50" r="42" class="frosted-glass" filter="url(#drop-shadow-sm)" />
        
        <!-- Objek Utama Volumetrik 3D -->
        <g filter="url(#drop-shadow-sm)">
            <!-- Dokumen PDF (Resin Putih) -->
            <g filter="url(#inner-shadow)">
                <rect x="28" y="20" width="36" height="48" rx="6" fill="url(#glossy-white)" transform="rotate(-8 50 50)" />
            </g>
            
            <!-- Lensa Gambar / Ekstraktor (Resin Gelap) memotong dokumen -->
            <g filter="url(#inner-shadow)">
                <circle cx="58" cy="55" r="20" fill="url(#glossy-dark)" />
                <!-- Elemen gambar/fokus di dalam lensa -->
                <circle cx="58" cy="55" r="8" fill="#FF9500" />
                <circle cx="62" cy="51" r="3" fill="#FF2D55" />
            </g>
        </g>
        
        <!-- Tipografi (Paling Atas) -->
        <text x="50" y="82" font-family="'Space Grotesk', sans-serif" font-weight="bold" font-size="11" fill="#FFFFFF" text-anchor="middle" filter="url(#drop-shadow-sm)" letter-spacing="1">HI-RES</text>
    </svg_elements>
    <visual_prompt>Komposisi ini menggunakan filosofi "Ekstraksi Visual". Dokumen putih bergaya resin melambangkan PDF asli yang statis, sementara "lensa" gelap volumetrik dengan aksen oranye terang menyimbolkan proses pengekstrakan gambar (fokus lensa) dengan resolusi tinggi. Skema warna hangat (Pink ke Oranye) dipilih untuk memberi kesan magis, cepat, dan kreatif, melepaskan diri dari warna biru korporat yang membosankan.</visual_prompt>
</icon_design>
