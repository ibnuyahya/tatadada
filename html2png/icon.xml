<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>HTML to 4K PNG</app_name>
    <colors>
        <color_start>#FF2A54</color_start>
        <color_end>#FF9F0A</color_end>
    </colors>
    <background_style>
        <ornament>ios17_fluid_wave</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.82</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Layer 1: Base Frosted Glass Framing (visionOS Style) -->
        <circle cx="50" cy="50" r="42" class="frosted-glass" filter="url(#drop-shadow-sm)" />
        
        <!-- Layer 2: Main Volumetric Objects (Code Window & Camera) -->
        <g filter="url(#drop-shadow-sm)">
            <!-- Code Window (Background layer) -->
            <g filter="url(#inner-shadow)">
                <rect x="22" y="24" width="46" height="40" rx="8" fill="url(#glossy-white)" />
                <rect x="28" y="32" width="16" height="3" rx="1.5" fill="url(#glossy-dark)" opacity="0.4" />
                <rect x="28" y="39" width="28" height="3" rx="1.5" fill="url(#glossy-dark)" opacity="0.4" />
                <rect x="28" y="46" width="20" height="3" rx="1.5" fill="url(#glossy-dark)" opacity="0.4" />
            </g>
            
            <!-- Camera/Image Render Body (Foreground layer) -->
            <g filter="url(#inner-shadow)">
                <rect x="36" y="44" width="42" height="32" rx="10" fill="url(#glossy-dark)" />
                <!-- Camera Lens Ring -->
                <circle cx="57" cy="60" r="11" fill="url(#glossy-white)" />
                <!-- Camera Lens Core (Accent Color) -->
                <circle cx="57" cy="60" r="5" fill="#FF9F0A" />
                <!-- Camera Flash -->
                <circle cx="44" cy="52" r="2.5" fill="url(#glossy-white)" />
            </g>
        </g>
        
        <!-- Layer 3: Typography -->
        <text x="50" y="86" font-family="'Space Grotesk', sans-serif" font-weight="bold" font-size="10" fill="#FFFFFF" text-anchor="middle" filter="url(#drop-shadow-sm)">Posterize</text>
    </svg_elements>
    <visual_prompt>Desain ini menggabungkan jendela kode (glossy white) di belakang dengan kamera digital (glossy dark) dan inti lensa yang menyala (oranye) di depan. Komposisi bertingkat ini menyimbolkan konversi secara langsung dari sintaks HTML menjadi gambar resolusi tinggi. Palet warna Fuchsia-Orange yang solid dan hangat memberikan kesan kreatif, mutakhir, dan memecah kebiasaan dominasi warna biru pada aplikasi koding konvensional.</visual_prompt>
</icon_design>
