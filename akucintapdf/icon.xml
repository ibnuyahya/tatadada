<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>AkuCintaPDF</app_name>
    <colors>
        <color_start>#FF2D55</color_start>
        <color_end>#FF9500</color_end>
    </colors>
    <background_style>
        <ornament>aurora</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.85</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Layer 1: Latar Belakang / Framing (Paling Bawah) -->
        <circle cx="50" cy="50" r="42" class="frosted-glass" filter="url(#drop-shadow-sm)" />
        
        <!-- Layer 2 & 3: Objek Utama & Ornamen (Kertas + Hati Berbinar) -->
        <g filter="url(#drop-shadow-sm)">
            <!-- Kertas Dasar -->
            <g filter="url(#inner-shadow)">
                <rect x="25" y="18" width="50" height="64" rx="12" fill="url(#glossy-white)" />
                <!-- Sudut Lipatan Kertas -->
                <path d="M 60 18 L 75 33 L 60 33 Z" fill="url(#glossy-dark)" opacity="0.1" />
            </g>

            <!-- Cahaya Berbinar (Glow Background) di belakang Hati -->
            <circle cx="50" cy="50" r="14" fill="#FF9500" opacity="0.3" filter="url(#drop-shadow-sm)" />

            <!-- Hati (Love) Volumetrik -->
            <g filter="url(#inner-shadow)">
                <path d="M 50 44 C 47 39 40 39 40 46 C 40 53 50 60 50 60 C 50 60 60 53 60 46 C 60 39 53 39 50 44 Z" fill="#FF2D55" />
            </g>

            <!-- Sparkles (Efek Bintang Berbinar) -->
            <!-- Bintang Kanan Atas -->
            <path d="M 63 36 Q 63 40 67 40 Q 63 40 63 44 Q 63 40 59 40 Q 63 40 63 36 Z" fill="#FF9500" />
            <!-- Bintang Kiri Bawah -->
            <path d="M 37 57 Q 37 60 40 60 Q 37 60 37 63 Q 37 60 34 60 Q 37 60 37 57 Z" fill="#FF2D55" />
        </g>
        
        <!-- Layer 4: Tipografi (Paling Atas) -->
        <!-- Teks "Aku" -->
        <text x="50" y="38" font-family="'Pacifico', cursive" font-size="12" fill="#0f172a" text-anchor="middle">Aku</text>
        <!-- Teks "PDF" -->
        <text x="50" y="74" font-family="'Space Grotesk', sans-serif" font-size="14" font-weight="bold" fill="#0f172a" text-anchor="middle">PDF</text>
    </svg_elements>
    <visual_prompt>Ikon AkuCintaPDF didesain secara literal menampilkan tipografi "Aku [Hati Merah] PDF" di atas kanvas kertas 3D (glossy-white). Bentuk hati dipahat menggunakan kurva geometris tanpa batas unicode, dengan isian Apple Pink/Red (#FF2D55) yang diberi inner-shadow untuk kesan volumetrik. Efek 'berbinar' diciptakan melalui pendaran cahaya (glow) melingkar di belakang hati dan dua ornamen bintang kecil empat sudut di sekitarnya. Latar belakang aurora yang mengalir menambah kedalaman visual yang memukau ala visionOS, tanpa membuat ukuran hati menutupi tipografi.</visual_prompt>
</icon_design>
