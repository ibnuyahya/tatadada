<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>AkuCintaPDF</app_name>
    <colors>
        <color_start>#3b82f6</color_start>
        <color_end>#4f46e5</color_end>
    </colors>
    <background_style>
        <ornament>ios17_fluid_wave</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.82</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Latar Belakang / Framing (Paling Bawah) -->
        <circle cx="50" cy="50" r="42" class="frosted-glass" filter="url(#drop-shadow-sm)" />
        
        <!-- Objek Utama Volumetrik 3D -->
        <g filter="url(#drop-shadow-sm)">
            <!-- Dokumen / Kertas PDF base -->
            <g filter="url(#inner-shadow)">
                <rect x="28" y="20" width="44" height="56" rx="8" fill="url(#glossy-white)" />
                <!-- Sudut lipatan kertas -->
                <path d="M 56 20 L 72 36 L 56 36 Z" fill="url(#glossy-dark)" opacity="0.3" />
                
                <!-- Elemen Lensa/Pemindai Kriptografi (Glossy Dark) -->
                <circle cx="50" cy="48" r="14" fill="url(#glossy-dark)" />
                
                <!-- Aksen Merah PDF / Laser Scanner -->
                <circle cx="50" cy="48" r="6" fill="#ef4444" filter="url(#inner-shadow)" />
            </g>
        </g>
        
        <!-- Tipografi (Paling Atas) -->
        <text x="50" y="86" font-family="'Space Grotesk', sans-serif" font-size="10" font-weight="bold" fill="#0f172a" text-anchor="middle" filter="url(#drop-shadow-sm)"></text>
    </svg_elements>
    <visual_prompt>Ikon aplikasi menggunakan material frosted-glass sebagai base, menampilkan tumpukan kertas dokumen 3D berbalut glossy-white. Di bagian tengah, terdapat lensa glossy-dark dengan titik api laser merah solid yang merepresentasikan fitur canggih pemindai (Scanner/OCR) dan ekstraktor Kriptografi PAdES. Tipografi menggunakan Space Grotesk untuk memberikan kesan modern, bersih, dan teknikal ala visionOS.</visual_prompt>
</icon_design>
