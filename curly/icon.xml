<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>Curly</app_name>
    <colors>
        <color_start>#2563EB</color_start> <!-- Blue 600 -->
        <color_end>#4F46E5</color_end> <!-- Indigo 600 -->
    </colors>
    <background_style>
        <ornament>ios17_fluid_wave</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.80</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Layer 1: Latar Belakang Cincin Material Kaca (Frosted Glass) -->
        <circle cx="50" cy="50" r="42" class="frosted-glass" filter="url(#drop-shadow-sm)" />
        
        <!-- Layer 2 & 3: Objek Utama (Terminal Volumetrik 3D & Aksen Neon) -->
        <g filter="url(#drop-shadow-sm)">
            <g filter="url(#inner-shadow)">
                <!-- Cangkang Terminal -->
                <rect x="18" y="25" width="64" height="42" rx="10" fill="url(#glossy-white)" />
                <!-- Layar Hitam (Glossy Dark) -->
                <rect x="22" y="29" width="56" height="34" rx="6" fill="url(#glossy-dark)" />
                
                <!-- Indikator API Status (Hijau Menyala) -->
                <circle cx="32" cy="46" r="4" fill="#10B981" />
                
                <!-- Simbol Prompt Terminal / Arrow Request -->
                <path d="M 40 40 L 48 46 L 40 52" fill="none" stroke="#38BDF8" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" />
                
                <!-- Kursor Aktif (Pink Aksen) -->
                <line x1="53" y1="52" x2="63" y2="52" stroke="#F472B6" stroke-width="4" stroke-linecap="round" />
            </g>
        </g>
        
        <!-- Layer 4: Tipografi (Modern/Tekno Space Grotesk) -->
        <text x="50" y="85" font-family="'Space Grotesk', sans-serif" font-size="13" font-weight="bold" fill="#FFFFFF" text-anchor="middle" filter="url(#drop-shadow-sm)">CURLY</text>
    </svg_elements>
    <visual_prompt>Komposisi ikon ini menyimbolkan request HTTP/cURL modern. Memiliki lapisan dasar frosted-glass visionOS, dengan sebuah terminal volumetrik di tengah yang menggunakan material glossy-white dan rongga layar glossy-dark. Terdapat panah cyan dan kursor pink tebal di dalamnya yang mewujudkan interaksi dinamis antara server dan klien. Tipografi "CURLY" di bagian bawah mempertegas kesan futuristik dan kokoh.</visual_prompt>
</icon_design>
