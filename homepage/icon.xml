<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>IconXstudio</app_name>
    <colors>
        <color_start>#FF2D55</color_start>
        <color_end>#5E5CE6</color_end>
    </colors>
    <background_style>
        <ornament>ios17_fluid_wave</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.82</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Layer 1: Latar Belakang / Framing -->
        <circle cx="50" cy="50" r="44" class="frosted-glass" filter="url(#drop-shadow-sm)" />
        
        <!-- Layer 2: Objek Utama Volumetrik 3D -->
        <g filter="url(#drop-shadow-sm)">
            <g filter="url(#inner-shadow)">
                <!-- Pilar Kiri Atas -> Kanan Bawah (Resin Putih) -->
                <rect x="26" y="41" width="48" height="18" rx="9" transform="rotate(45 50 50)" fill="url(#glossy-white)" />
                <!-- Pilar Kanan Atas -> Kiri Bawah (Resin Gelap) -->
                <rect x="26" y="41" width="48" height="18" rx="9" transform="rotate(-45 50 50)" fill="url(#glossy-dark)" />
                
                <!-- Core Cyan di Tengah -->
                <circle cx="50" cy="50" r="14" fill="#32ADE6" />
            </g>
        </g>
        
        <!-- Layer 3: Aksen / Ornamen Padat -->
        <g filter="url(#drop-shadow-sm)">
            <!-- Lensa Dalam -->
            <circle cx="50" cy="50" r="8" fill="url(#glossy-dark)" filter="url(#inner-shadow)" />
            <circle cx="52.5" cy="47.5" r="2.5" fill="url(#glossy-white)" opacity="0.9" />
            
            <!-- Bintang/Titik Orbit -->
            <circle cx="22" cy="22" r="4.5" fill="url(#glossy-white)" filter="url(#inner-shadow)" />
            <circle cx="78" cy="28" r="3.5" fill="#FFD60A" filter="url(#inner-shadow)" />
            <circle cx="74" cy="78" r="5" fill="url(#glossy-white)" filter="url(#inner-shadow)" />
        </g>
        
        <!-- Layer 4: Tipografi -->
        <text x="50" y="85" font-family="'Righteous', cursive" font-size="12" fill="#FFFFFF" text-anchor="middle" filter="url(#drop-shadow-sm)">STUDIO</text>
    </svg_elements>
    <visual_prompt>Komposisi menonjolkan persilangan dua pilar resin kontras (putih dan gelap) yang membentuk huruf X dinamis, diikat oleh core lensa cyan menyala bergaya aperture di tengahnya. Tiga titik orbit asimetris memperkuat kedalaman ruang (spatial depth), sementara tipografi 'STUDIO' berfont Righteous mengakar kuat di bagian bawah berlatarkan ombak fluid pink-ungu.</visual_prompt>
</icon_design>
