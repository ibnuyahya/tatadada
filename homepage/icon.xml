<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>Tatadada Portal</app_name>
    <colors>
        <color_start>#007AFF</color_start>
        <color_end>#5856D6</color_end>
    </colors>
    <background_style>
        <ornament>aurora</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.82</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Layer 1: Framing Kaca Crystal -->
        <circle cx="50" cy="50" r="44" class="frosted-glass" filter="url(#drop-shadow-sm)" />
        
        <!-- Layer 2: Objek Utama (Portal Gateway) -->
        <g filter="url(#drop-shadow-sm)">
            <g filter="url(#inner-shadow)">
                <!-- Pilar Geometris resin putih membentuk gerbang -->
                <rect x="28" y="32" width="12" height="40" rx="6" fill="url(#glossy-white)" />
                <rect x="60" y="32" width="12" height="40" rx="6" fill="url(#glossy-white)" />
                <rect x="28" y="32" width="44" height="12" rx="6" fill="url(#glossy-white)" />
                
                <!-- Core Aperture (Pusat Data) -->
                <circle cx="50" cy="52" r="14" fill="url(#glossy-dark)" />
                <circle cx="50" cy="52" r="6" fill="#32ADE6" />
            </g>
        </g>
        
        <!-- Layer 3: Aksen Partikel -->
        <circle cx="78" cy="22" r="4" fill="#FFD60A" filter="url(#drop-shadow-sm)" />
        <circle cx="22" cy="78" r="3" fill="url(#glossy-white)" opacity="0.8" />
        
        <!-- Layer 4: Tipografi Studio -->
        <text x="50" y="85" font-family="'Space Grotesk', sans-serif" font-size="10" font-weight="700" fill="#FFFFFF" text-anchor="middle" filter="url(#drop-shadow-sm)" style="letter-spacing: 3px;">ENGINE</text>
    </svg_elements>
    <visual_prompt>Desain menonjolkan 'Gateway' resin putih chunky dengan inti aperture lensa gelap yang melambangkan pusat kendali data. Aksen titik kuning orbit memberikan dimensi spasial, dibingkai oleh material kaca kristal di atas gradien iOS biru klasik.</visual_prompt>
</icon_design>
