<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>SiFoncu</app_name>
    <colors>
        <color_start>#F472B6</color_start> <!-- Pink 400 -->
        <color_end>#6366F1</color_end> <!-- Indigo 500 -->
    </colors>
    <background_style>
        <ornament>aurora</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.80</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Layer 1: Framing (Glossy Base) -->
        <rect x="2" y="2" width="28" height="28" rx="7" fill="url(#glossy-dark)" opacity="0.3"/>
        
        <!-- Layer 2: Objek Utama (Magic Wand) -->
        <g id="Layer_2_Main_Object">
            <path d="M10 22L22 10" stroke="url(#glossy-white)" stroke-width="2.5" stroke-linecap="round" filter="url(#drop-shadow-sm)"/>
            <path d="M22 10l-4-4" stroke="url(#glossy-white)" stroke-width="2.5" stroke-linecap="round" filter="url(#drop-shadow-sm)"/>
            <path d="M10 22l4 4" stroke="url(#glossy-white)" stroke-width="2.5" stroke-linecap="round" filter="url(#drop-shadow-sm)"/>
            <!-- Sparkles -->
            <circle cx="23" cy="7" r="1.5" fill="#FFF" filter="url(#drop-shadow-sm)"/>
            <circle cx="7" cy="23" r="1" fill="#FFF" filter="url(#drop-shadow-sm)"/>
            <circle cx="9" cy="11" r="1.2" fill="#FFF" filter="url(#drop-shadow-sm)"/>
        </g>
        
        <!-- Layer 3: Aksen & Tipografi (Fancy Letters) -->
        <g id="Layer_3_Accent">
            <!-- Huruf 'S' dan 'F' bergaya dekoratif memancar dari tongkat sihir -->
            <text x="6" y="15" font-family="Pacifico" font-size="7" fill="url(#glossy-white)" filter="url(#drop-shadow-sm)" opacity="0.9">S</text>
            <text x="18" y="25" font-family="Pacifico" font-size="8" fill="url(#glossy-white)" filter="url(#drop-shadow-sm)">F</text>
        </g>
    </svg_elements>
    <visual_prompt>Desain ikon SiFoncu merepresentasikan keajaiban transformasi teks (aesthetic/vaporwave). Tongkat sihir (magic wand) melambangkan engine konversi yang menyihir teks biasa menjadi teks dekoratif (disimbolkan dengan huruf S & F bergaya Pacifico yang melayang). Latar belakang aurora bergradasi Pink ke Indigo memberikan nuansa kreatif dan imajinatif, sementara material glossy memberikan kedalaman visual berdimensi ala visionOS.</visual_prompt>
</icon_design>
