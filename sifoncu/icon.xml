<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>SiFoncu</app_name>
    <colors>
        <color_start>#ec4899</color_start>
        <color_end>#6366f1</color_end>
    </colors>
    <background_style>
        <ornament>aurora</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.8</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Tongkat Sihir Utama (Magic Wand Base) -->
        <g transform="rotate(45, 50, 50)">
            <rect x="46" y="20" width="8" height="60" fill="url(#glossy-white)" filter="url(#drop-shadow-sm)" rx="4"/>
            <!-- Ujung Tongkat -->
            <circle cx="50" cy="16" r="8" fill="url(#glossy-white)" filter="url(#inner-shadow)"/>
            <!-- Handle Bawah -->
            <rect x="45" y="65" width="10" height="20" fill="url(#glossy-dark)" filter="url(#inner-shadow)" rx="3" opacity="0.8"/>
        </g>
        
        <!-- Partikel Keajaiban (Sparkles) -->
        <!-- Sparkle 1 (Kanan Atas) -->
        <polygon points="75,15 78,25 88,28 78,31 75,41 72,31 62,28 72,25" fill="url(#glossy-white)" opacity="0.9" filter="url(#drop-shadow-sm)"/>
        <!-- Sparkle 2 (Kiri Bawah) -->
        <polygon points="25,60 27,66 33,68 27,70 25,76 23,70 17,68 23,66" fill="url(#glossy-white)" opacity="0.7" filter="url(#drop-shadow-sm)"/>
        <!-- Sparkle 3 (Tengah Kiri) -->
        <circle cx="20" cy="35" r="4" fill="url(#glossy-white)" opacity="0.6"/>
        <circle cx="80" cy="65" r="3" fill="url(#glossy-white)" opacity="0.5"/>
    </svg_elements>
    <visual_prompt>Ikon ini menggunakan metafora "Tongkat Sihir" (Magic Wand) miring 45 derajat yang memancarkan "Partikel Bintang" (Sparkles), melambangkan transformasi instan teks normal menjadi teks 'ajaib' atau fancy. Seluruh elemen dibangun dari geometri padat (rect, circle, polygon) berlapis filter glossy dan inner-shadow khas visionOS di atas palet aurora Pink ke Indigo yang melambangkan kreativitas, estetika retro/vaporwave, dan keunikan.</visual_prompt>
</icon_design>
