<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>CSVtoPDF</app_name>
    <colors>
        <color_start>#f43f5e</color_start>
        <color_end>#f97316</color_end>
    </colors>
    <background_style>
        <ornament>ios17_fluid_wave</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.80</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Lapis Dasar: Plate kaca frosted -->
        <rect x="15" y="15" width="70" height="70" rx="18" fill="url(#glossy-white)" class="frosted-glass" filter="url(#drop-shadow-sm)"/>
        
        <!-- Lapis 2: Piringan Data Mentah CSV -->
        <rect x="25" y="25" width="30" height="40" rx="4" fill="#cbd5e1" filter="url(#inner-shadow)"/>
        <rect x="30" y="32" width="20" height="4" rx="2" fill="#94a3b8"/>
        <rect x="30" y="40" width="12" height="4" rx="2" fill="#94a3b8"/>
        <rect x="30" y="48" width="18" height="4" rx="2" fill="#94a3b8"/>
        
        <!-- Lapis 3: Lempengan Ekstraksi Dokumen (PDF) menumpuk di atasnya -->
        <rect x="45" y="35" width="30" height="40" rx="4" fill="url(#glossy-dark)" filter="url(#drop-shadow-sm)"/>
        
        <!-- Lapis 4: Lensa Data Core yang memproses / menarik nilai dari CSV -->
        <circle cx="60" cy="55" r="10" fill="#f43f5e" filter="url(#inner-shadow)"/>
        <circle cx="60" cy="55" r="5" fill="#f97316"/>
    </svg_elements>
    <visual_prompt>Ikon melambangkan dua lempengan dokumen. Lembar belakang (terang) mewakili data mentah CSV dengan grid baris-baris padat. Lembar depan (gelap) menumpuk di atasnya mewakili output PDF akhir, dengan inti lensa "Data Core" berwarna gradasi Rose-Orange menyala di tengah yang melambangkan mesin ekstraksi matriks yang mengubah teks mentah menjadi dokumen tertata rapat secara instan.</visual_prompt>
</icon_design>
