<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>Sodakoh 2048</app_name>
    <colors>
        <color_start>#fcd34d</color_start>
        <color_end>#b45309</color_end>
    </colors>
    <background_style>
        <ornament>aurora</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.80</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Outer Golden Ring -->
        <circle cx="50" cy="50" r="40" fill="url(#glossy-dark)" filter="url(#drop-shadow-sm)"/>
        <circle cx="50" cy="50" r="38" fill="url(#glossy-white)"/>
        
        <!-- Inner Coin Face -->
        <circle cx="50" cy="50" r="32" fill="#d97706" filter="url(#inner-shadow)"/>
        
        <!-- Islamic Crescent Motif -->
        <path d="M 60 30 A 20 20 0 1 0 60 70 A 25 25 0 1 1 60 30 Z" fill="#fef3c7" opacity="0.3" class="frosted-glass"/>
        
        <!-- Typography "2048" Embossed -->
        <text x="50" y="56" font-family="Space Grotesk" font-weight="900" font-size="20" fill="#fef3c7" text-anchor="middle" filter="url(#drop-shadow-sm)">2048</text>
        
