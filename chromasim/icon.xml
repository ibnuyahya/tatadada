<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>ChromaSim Pro</app_name>
    <colors>
        <color_start>#ec4899</color_start> <!-- Pink 500 -->
        <color_end>#3b82f6</color_end> <!-- Blue 500 -->
    </colors>
    <background_style>
        <ornament>ios17_fluid_wave</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.80</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Lensa Utama / Mata -->
        <g filter="url(#drop-shadow-md)">
            <ellipse cx="50" cy="50" rx="35" ry="25" fill="#ffffff" class="frosted-glass"/>
            <!-- Pupil (Warna-warni yang mewakili spektrum) -->
            <circle cx="50" cy="50" r="16" fill="url(#glossy-dark)"/>
            <!-- Iris Warna: Merah/Hijau/Biru Solid (Tidak menggunakan garis) -->
            <path d="M50,34 A16,16 0 0,1 66,50 L50,50 Z" fill="#ef4444"/>
            <path d="M66,50 A16,16 0 0,1 50,66 L50,50 Z" fill="#22c55e"/>
            <path d="M50,66 A16,16 0 0,1 34,50 L50,50 Z" fill="#3b82f6"/>
            <!-- Pantulan Cahaya Lensa -->
            <ellipse cx="43" cy="43" rx="5" ry="3" fill="#ffffff" opacity="0.8" transform="rotate(-30 43 43)"/>
        </g>
        <!-- Irisan Monokrom (Menggambarkan filter buta warna) -->
        <path d="M15,50 A35,25 0 0,0 50,75 L50,25 A35,25 0 0,0 15,50 Z" fill="#94a3b8" opacity="0.9" style="mix-blend-mode: overlay;"/>
    </svg_elements>
    <visual_prompt>Ikon berbentuk lensa mata 3D tebal beraksen frosted-glass. Pupil dipecah menjadi volume solid RGB untuk melambangkan spektrum warna, sementara separuh lensa dilapisi filter monokrom overlay yang melebur ke dalam, mewakili lensa simulator buta warna yang presisi.</visual_prompt>
</icon_design>
