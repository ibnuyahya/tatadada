<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>ReformatSuara</app_name>
    <colors>
        <color_start>#8A2387</color_start>
        <color_end>#F27121</color_end>
    </colors>
    <background_style>
        <ornament>ios17_fluid_wave</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.82</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Dasar Framing Frosted Glass -->
        <circle cx="50" cy="50" r="42" class="frosted-glass" filter="url(#drop-shadow-sm)" />
        
        <!-- Objek Utama Volumetrik (Piringan Hitam Audio & Lensa) -->
        <g filter="url(#drop-shadow-sm)">
            <g filter="url(#inner-shadow)">
                <circle cx="50" cy="50" r="28" fill="url(#glossy-dark)" />
                <circle cx="50" cy="50" r="12" fill="url(#glossy-white)" />
                <!-- Lubang piringan -->
                <circle cx="50" cy="50" r="4" fill="#1C1C1E" />
            </g>
        </g>
        
        <!-- Gelombang Suara (Aksen Vibrant Warna-warni) -->
        <g filter="url(#drop-shadow-sm)">
            <g filter="url(#inner-shadow)">
                <!-- Kiri -->
                <rect x="30" y="40" width="4" height="20" rx="2" fill="#E94057" />
                <rect x="38" y="30" width="4" height="40" rx="2" fill="#F27121" />
                <!-- Kanan -->
                <rect x="58" y="35" width="4" height="30" rx="2" fill="#8A2387" />
                <rect x="66" y="42" width="4" height="16" rx="2" fill="#E94057" />
            </g>
        </g>
        
        <!-- Ikon Refresh/Format kecil di pinggir bawah piringan -->
        <g filter="url(#drop-shadow-sm)">
            <circle cx="68" cy="68" r="10" fill="#3b82f6" filter="url(#inner-shadow)" />
            <path d="M 64 68 A 4 4 0 1 1 68 72 L 68 70 M 68 72 L 70 72" fill="none" stroke="#FFFFFF" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </g>
    </svg_elements>
    <visual_prompt>Ikon ReformatSuara dirancang menggunakan palet sunset gradient (Magenta-ke-Oranye) untuk mengomunikasikan transformasi gelombang suara yang dinamis. Objek utama berupa piringan hitam audio berbahan glossy-dark yang dipadukan dengan cincin frosted-glass, memberikan kesan kedalaman spasial ala visionOS. Aksen gelombang suara asimetris warna-warni memecah dominasi gelap dan menambah kesan premium.</visual_prompt>
</icon_design>
