<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>Raden2026</app_name>
    <colors>
        <color_start>#B45309</color_start>
        <color_end>#78350F</color_end>
    </colors>
    <background_style>
        <ornament>ios17_fluid_wave</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.85</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Latar Belakang / Framing (Paling Bawah) -->
        <circle cx="50" cy="50" r="42" class="frosted-glass" filter="url(#drop-shadow-sm)" />
        
        <!-- Objek Utama Volumetrik 3D: Cincin Mesin Tembaga/Steampunk -->
        <g filter="url(#drop-shadow-sm)">
            <g filter="url(#inner-shadow)">
                <circle cx="50" cy="50" r="32" fill="url(#glossy-white)" />
                <circle cx="50" cy="50" r="26" fill="url(#glossy-dark)" />
                
                <!-- Aksen Geometris Sayap/Mesin -->
                <path d="M 50 15 L 60 40 L 75 50 L 60 60 L 50 85 L 40 60 L 25 50 L 40 40 Z" fill="#FCD34D" filter="url(#drop-shadow-sm)"/>
                
                <!-- Inti Energi Bercahaya (Core) -->
                <circle cx="50" cy="50" r="10" fill="#EF4444" />
                <circle cx="50" cy="50" r="4" fill="#FFFFFF" opacity="0.8" />
            </g>
        </g>
        
        <!-- Tipografi (Paling Atas) -->
        <text x="50" y="82" font-family="'Space Grotesk', sans-serif" font-size="11" font-weight="bold" fill="#FFFFFF" text-anchor="middle" filter="url(#drop-shadow-sm)" letter-spacing="1">RADEN</text>
    </svg_elements>
    <visual_prompt>Desain ikon ini merepresentasikan kokpit mesin uap futuristik (Steampunk Armada). Latar 'frosted-glass' membingkai cincin tembaga volumetrik, dengan rongga lensa 'glossy-dark' di tengahnya. Bintang bersudut tajam berwarna emas melambangkan sayap armada tempur, sementara inti merah menyala (Red Core) memberikan kesan energi mesin uap yang siap meledak. Tipografi 'Space Grotesk' menegaskan identitas fiksi ilmiah yang tangguh.</visual_prompt>
</icon_design>
