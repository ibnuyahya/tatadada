<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>AlatJaringan</app_name>
    <colors>
        <color_start>#0ea5e9</color_start>
        <color_end>#6366f1</color_end>
    </colors>
    <background_style>
        <ornament>ios17_fluid_wave</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.85</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Latar Belakang / Framing (Paling Bawah) -->
        <circle cx="50" cy="50" r="42" class="frosted-glass" filter="url(#drop-shadow-sm)" />
        
        <!-- Objek Utama Volumetrik 3D -->
        <g filter="url(#drop-shadow-sm)">
            <g filter="url(#inner-shadow)">
                <!-- Casing Luar Monitor/Alat (Glossy White) -->
                <rect x="20" y="22" width="60" height="48" rx="12" fill="url(#glossy-white)" />
                
                <!-- Layar Dalam / Rongga Kedalaman (Glossy Dark) -->
                <rect x="26" y="28" width="48" height="36" rx="8" fill="url(#glossy-dark)" />
                
                <!-- Garis Koneksi Topologi Jaringan -->
                <line x1="38" y1="38" x2="62" y2="44" stroke="url(#glossy-white)" stroke-width="2" opacity="0.6" />
                <line x1="62" y1="44" x2="48" y2="54" stroke="url(#glossy-white)" stroke-width="2" opacity="0.6" />
                <line x1="38" y1="38" x2="48" y2="54" stroke="url(#glossy-white)" stroke-width="2" opacity="0.6" />
                
                <!-- Node Jaringan Berwarna Solid (Kontras visionOS) -->
                <!-- Node Kiri Atas (Magenta) -->
                <circle cx="38" cy="38" r="4.5" fill="#FF2D55" />
                <!-- Node Kanan (Cyan) -->
                <circle cx="62" cy="44" r="5.5" fill="#32ADE6" />
                <!-- Node Bawah (Hijau) -->
                <circle cx="48" cy="54" r="4.5" fill="#34C759" />
            </g>
        </g>
        
        <!-- Tipografi (Paling Atas) -->
        <text x="50" y="82" font-family="'Space Grotesk', sans-serif" font-weight="bold" font-size="9" fill="#FFFFFF" text-anchor="middle" filter="url(#drop-shadow-sm)">NET.TOOLS</text>
    </svg_elements>
    <visual_prompt>Ikon berbentuk monitor diagnostik jaringan volumetrik. Latar belakang menggunakan cincin kaca frosted-glass. Objek utama berupa casing putih glossy tebal dengan rongga layar glossy-dark di dalamnya untuk menciptakan ilusi kedalaman (depth). Di dalam layar, terdapat topologi jaringan dengan node membulat berwarna solid (Magenta, Cyan, Hijau Apple) yang memecah warna monokrom dan menonjolkan estetika premium ala visionOS.</visual_prompt>
</icon_design>
