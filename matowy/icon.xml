<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>MATOWY</app_name>
    <colors>
        <color_start>#3b82f6</color_start>
        <color_end>#8b5cf6</color_end>
    </colors>
    <background_style>
        <ornament>ios17_fluid_wave</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.82</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Latar Belakang / Framing (Frosted Glass Plate) -->
        <rect x="12" y="12" width="76" height="76" rx="20" class="frosted-glass" filter="url(#drop-shadow-sm)" />
        
        <!-- Objek Utama: Melting Geometry A4 Paper & Code Engine -->
        <g filter="url(#drop-shadow-sm)">
            <g filter="url(#inner-shadow)">
                <!-- Kertas Dasar Volumetrik -->
                <rect x="26" y="20" width="48" height="60" rx="8" fill="url(#glossy-white)" />
                
                <!-- Elemen Gutter/Margin Kiri (Area Code Editor) -->
                <rect x="26" y="20" width="14" height="60" rx="0" fill="url(#glossy-dark)" />
                
                <!-- Syntax Nodes (Resin Solid Aksen) -->
                <circle cx="33" cy="32" r="2.5" fill="#3b82f6" />
                <circle cx="33" cy="42" r="2.5" fill="#8b5cf6" />
                <circle cx="33" cy="52" r="2.5" fill="#10b981" />
                
                <!-- Format Garis Teks Dokumen -->
                <rect x="46" y="30" width="20" height="4" rx="2" fill="url(#glossy-dark)" />
                <rect x="46" y="40" width="12" height="4" rx="2" fill="url(#glossy-dark)" />
                <rect x="46" y="50" width="16" height="4" rx="2" fill="url(#glossy-dark)" />
            </g>
        </g>
        
        <!-- Tipografi Premium -->
        <text x="50" y="80" font-family="'Space Grotesk', sans-serif" font-weight="bold" font-size="10" letter-spacing="1" fill="#FFFFFF" text-anchor="middle" filter="url(#drop-shadow-sm)"></text>
    </svg_elements>
    <visual_prompt>Desain ini memadukan estetika ruang kerja ganda (Split View) ke dalam satu ikon volumetrik. Panel kiri berbahan 'glossy-dark' merepresentasikan Gutter Editor Markdown dengan indikator node berwarna neon, sementara sisa area 'glossy-white' merepresentasikan hasil akhir kertas A4. Dilebur dengan inner-shadow (melting geometry) di atas frosted-glass, menciptakan kesan alat profesional premium yang adaptif.</visual_prompt>
</icon_design>
