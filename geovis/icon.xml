<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>GeoVis</app_name>
    <colors>
        <color_start>#FF2D55</color_start>
        <color_end>#5856D6</color_end>
    </colors>
    <background_style>
        <ornament>aurora</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.82</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Latar Belakang / Framing (Paling Bawah) -->
        <circle cx="50" cy="50" r="42" class="frosted-glass" filter="url(#drop-shadow-sm)" />
        
        <!-- Objek Utama Volumetrik 3D: Prisma Hexagonal Transparan -->
        <g filter="url(#drop-shadow-sm)">
            <!-- Sisi belakang objek (Resin Gelap) -->
            <path d="M35 30 L65 30 L75 50 L65 70 L35 70 L25 50 Z" fill="url(#glossy-dark)" filter="url(#inner-shadow)" opacity="0.8" />
            
            <!-- Sisi depan objek (Resin Putih / Kaca) -->
            <path d="M40 35 L60 35 L68 50 L60 65 L40 65 L32 50 Z" fill="url(#glossy-white)" filter="url(#inner-shadow)" opacity="0.9" />
            
            <!-- Aksen Titik Pusat & Konektor Sudut (Resin Berwarna Kontras) -->
            <circle cx="50" cy="50" r="10" fill="url(#glossy-dark)" filter="url(#inner-shadow)" />
            <circle cx="50" cy="50" r="4" fill="#FFCC00" filter="url(#inner-shadow)" />
        </g>
        
        <!-- Tipografi (Paling Atas) -->
        <text x="50" y="82" font-family="'Space Grotesk', sans-serif" font-weight="bold" font-size="11" fill="#FFFFFF" text-anchor="middle" letter-spacing="1" filter="url(#drop-shadow-sm)">GEO</text>
    </svg_elements>
    <visual_prompt>Filosofi desain memancarkan aura matematika murni melalui palet warna eksklusif Apple (Pink #FF2D55 ke Purple #5856D6) berlatar "aurora" untuk lepas dari dominasi biru klasik. Di tengah terdapat bentuk polihedron yang diarsiteki dengan lapisan transparan (glossy-white di atas glossy-dark) menciptakan ilusi volume. Sebuah node emas (#FFCC00) di pusat mewakili presisi titik dan sudut geometri.</visual_prompt>
</icon_design>
