<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>TidyDoc</app_name>
    <colors>
        <color_start>#10b981</color_start> <!-- Emerald Terang -->
        <color_end>#0f766e</color_end>   <!-- Teal Dalam -->
    </colors>
    <background_style>
        <ornament>ios17_fluid_wave</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.82</icon_scale>
    </proportions>
    <svg_elements>
        <!-- LAYER 1: Base Document Blueprint (Volume Solid) -->
        <rect x="25" y="15" width="50" height="70" rx="6" fill="url(#glossy-white)" filter="url(#drop-shadow-sm)"/>
        
        <!-- LAYER 2: Text Lines (Pre-Tidy/Messy) -->
        <rect x="35" y="30" width="30" height="4" rx="2" fill="rgba(15, 23, 42, 0.4)" filter="url(#inner-shadow)"/>
        <rect x="35" y="42" width="22" height="4" rx="2" fill="rgba(15, 23, 42, 0.4)" filter="url(#inner-shadow)"/>
        <rect x="35" y="54" width="30" height="4" rx="2" fill="rgba(15, 23, 42, 0.4)" filter="url(#inner-shadow)"/>

        <!-- LAYER 3: Wand / Sparkle Sweep (The 'Tidy' Magic) -->
        <g filter="url(#drop-shadow-md)">
            <!-- Magic Orb Center -->
            <circle cx="65" cy="70" r="14" fill="url(#glossy-dark)" />
            <!-- Inner Glowing Emerald Core -->
            <circle cx="65" cy="70" r="6" fill="#10b981" filter="url(#inner-shadow)"/>
            
            <!-- Sparkles (Diamond Shape volume no-stroke) -->
            <path d="M 45 65 Q 50 65 50 60 Q 50 65 55 65 Q 50 65 50 70 Q 50 65 45 65 Z" fill="url(#glossy-white)"/>
            <path d="M 75 45 Q 78 45 78 42 Q 78 45 81 45 Q 78 45 78 48 Q 78 45 75 45 Z" fill="url(#glossy-white)"/>
        </g>
    </svg_elements>
    <visual_prompt>Geometri ikon menggambarkan selembar kertas tebal beresolusi yang mewakili "Dokumen" (Doc). Di atasnya terdapat bola pualam magis dengan debu intan geometrik (tanpa satu pun garis coretan stroke) yang menyapu melewati layar, mensimulasikan proses 'Tidy' atau penyapuan kotoran metadata menjadi selembar kanvas yang bersih dan murni.</visual_prompt>
</icon_design>
