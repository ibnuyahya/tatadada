<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>TidyDoc</app_name>
    <colors>
        <color_start>#10b981</color_start>
        <color_end>#0f766e</color_end>
    </colors>
    <background_style>
        <ornament>ios17_fluid_wave</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.82</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Layer 1: Document Base -->
        <rect x="25" y="15" width="50" height="70" rx="8" fill="url(#glossy-white)" filter="url(#drop-shadow-sm)"/>
        
        <!-- Layer 2: Text Lines (Messy) -->
        <rect x="35" y="30" width="30" height="6" rx="3" fill="#0f172a" opacity="0.3" filter="url(#inner-shadow)"/>
        <rect x="35" y="44" width="20" height="6" rx="3" fill="#0f172a" opacity="0.3" filter="url(#inner-shadow)"/>
        
        <!-- Layer 3: Tidy Magic Orb / Swoosh -->
        <g filter="url(#drop-shadow-md)">
            <!-- Magic Sphere -->
            <circle cx="65" cy="65" r="18" fill="url(#glossy-dark)" />
            <!-- Glowing Core -->
            <circle cx="65" cy="65" r="8" fill="#10b981" filter="url(#inner-shadow)"/>
            <!-- Sparkle Diamond -->
            <path d="M 45 60 Q 50 60 50 55 Q 50 60 55 60 Q 50 60 50 65 Q 50 60 45 60 Z" fill="url(#glossy-white)"/>
        </g>
    </svg_elements>
    <visual_prompt>Ikon menggambarkan fondasi selembar kertas bervolume tebal (dokumen) berwarna putih glossy. Di atasnya terdapat baris teks buram yang berantakan. Sebuah bola magis obsidian dengan inti zamrud pijar melebur (melting) di sudut kanan bawah, melepaskan partikel bintang padat, mempresentasikan proses "Tidy" (Perapihan) yang otomatis dan ajaib.</visual_prompt>
</icon_design>
