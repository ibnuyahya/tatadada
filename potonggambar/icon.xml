<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>PotongGambar</app_name>
    <colors>
        <color_start>#FF9500</color_start> <!-- Sunset Orange -->
        <color_end>#FF2D55</color_end> <!-- Vibrant Pink -->
    </colors>
    <background_style>
        <ornament>ios17_fluid_wave</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.82</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Latar Belakang Kaca / Framing -->
        <circle cx="50" cy="50" r="42" class="frosted-glass" filter="url(#drop-shadow-sm)" />
        
        <!-- Objek Utama Volumetrik 3D: Lensa & Bingkai Crop -->
        <g filter="url(#drop-shadow-sm)">
            <g filter="url(#inner-shadow)">
                <!-- Base bingkai membulat -->
                <rect x="22" y="22" width="56" height="56" rx="14" fill="url(#glossy-white)" />
                
                <!-- Lensa / Area Potong Gelap di Tengah -->
                <rect x="30" y="30" width="40" height="40" rx="8" fill="url(#glossy-dark)" />
                
                <!-- Titik Fokus (Aksen Kontras) -->
                <circle cx="50" cy="50" r="10" fill="#FF9500" />
                <circle cx="50" cy="50" r="4" fill="#FFFFFF" />

                <!-- Sudut Bingkai Crop (Ornamen Resin Putih) -->
                <path d="M 22 36 L 22 22 L 36 22" fill="none" stroke="url(#glossy-white)" stroke-width="6" stroke-linecap="round" stroke-linejoin="round" />
                <path d="M 78 64 L 78 78 L 64 78" fill="none" stroke="url(#glossy-white)" stroke-width="6" stroke-linecap="round" stroke-linejoin="round" />
            </g>
        </g>
        
        <!-- Tipografi Premium -->
        <text x="50" y="80" font-family="'Space Grotesk', sans-serif" font-weight="bold" font-size="11" fill="#FFFFFF" text-anchor="middle" filter="url(#drop-shadow-sm)"></text>
    </svg_elements>
    <visual_prompt>Ikon PotongGambar memadukan bingkai crop (resin putih) dengan sebuah lensa/fokus area (resin gelap) melayang di tengah. Palet Sunset (Orange-Magenta) dipilih untuk menonjolkan kreativitas visual yang vibrant dan energik. Sudut-sudut tumpang tindih menyimulasikan alat potong (crop tool) secara natural.</visual_prompt>
</icon_design>
