<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>Nyapuduar</app_name>
    <colors>
        <color_start>#B91C1C</color_start> <!-- Merah Darah Gelap (Danger) -->
        <color_end>#7F1D1D</color_end>   <!-- Merah Marun Ekstrem -->
    </colors>
    <background_style>
        <ornament>ios17_fluid_wave</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.82</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Layer 1: Framing Kaca Frosted -->
        <circle cx="50" cy="50" r="44" class="frosted-glass" filter="url(#drop-shadow-sm)" />
        
        <!-- Layer 2: Objek Utama Volumetrik (Ranjau/Bomb Metalik) -->
        <g filter="url(#drop-shadow-md)">
            <!-- Tubuh Ranjau (Dark Resin) -->
            <circle cx="50" cy="46" r="22" fill="url(#glossy-dark)" filter="url(#inner-shadow)" />
            
            <!-- Tanduk/Paku Ranjau (Glossy White Resin untuk kontras) -->
            <circle cx="28" cy="28" r="4" fill="url(#glossy-white)" filter="url(#inner-shadow)" />
            <circle cx="72" cy="28" r="4" fill="url(#glossy-white)" filter="url(#inner-shadow)" />
            <circle cx="22" cy="54" r="4" fill="url(#glossy-white)" filter="url(#inner-shadow)" />
            <circle cx="78" cy="54" r="4" fill="url(#glossy-white)" filter="url(#inner-shadow)" />
            <circle cx="50" cy="72" r="4" fill="url(#glossy-white)" filter="url(#inner-shadow)" />
        </g>
        
        <!-- Layer 3: Aksen Indikator Aktif (Neon Orange/Kuning) -->
        <g filter="url(#drop-shadow-sm)">
            <circle cx="50" cy="46" r="6" fill="#F59E0B" filter="url(#inner-shadow)" />
            <circle cx="50" cy="46" r="2" fill="#FEF3C7" />
        </g>
        
        <!-- Layer 4: Tipografi (Modern Tekno) -->
        <text x="50" y="86" font-family="'Space Grotesk', sans-serif" font-weight="bold" font-size="10" fill="#FFFFFF" text-anchor="middle" filter="url(#drop-shadow-sm)" letter-spacing="1">DUAR</text>
    </svg_elements>
    <visual_prompt>Desain ikon berfokus pada estetika bahaya (danger/tactical). Background menggunakan gradien merah gelap bergelombang (fluid wave). Objek utama adalah bentuk ranjau laut klasik 3D yang dipahat dari 'glossy-dark' resin dengan paku-paku 'glossy-white' untuk memberikan kontras material khas Apple. Inti ranjau menyala dengan warna oranye neon, memberikan nuansa tegang (explosive) yang elegan. Teks 'DUAR' melayang di bawah dengan font tekno modern.</visual_prompt>
</icon_design>
