<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>Desaku</app_name>
    <colors>
        <color_start>#10B981</color_start> <!-- Emerald Green -->
        <color_end>#F59E0B</color_end> <!-- Warm Amber -->
    </colors>
    <background_style>
        <ornament>ios17_fluid_wave</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.85</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Layer 1: Latar Belakang / Framing (Paling Bawah) -->
        <circle cx="50" cy="50" r="42" class="frosted-glass" filter="url(#drop-shadow-sm)" />
        
        <!-- Layer 2 & 3: Objek Utama Volumetrik 3D & Ornamen -->
        <g filter="url(#drop-shadow-sm)">
            
            <!-- Matahari (Aksen di belakang) -->
            <circle cx="65" cy="35" r="10" fill="#FCD34D" filter="url(#inner-shadow)" />

            <!-- Batang Pohon Kiri -->
            <rect x="28" y="55" width="4" height="15" rx="2" fill="url(#glossy-dark)" filter="url(#inner-shadow)" />
            <!-- Daun Pohon Kiri -->
            <circle cx="30" cy="50" r="12" fill="#10B981" filter="url(#inner-shadow)" />

            <!-- Bangunan Rumah Dasar -->
            <rect x="40" y="50" width="28" height="20" rx="3" fill="url(#glossy-white)" filter="url(#inner-shadow)" />
            <!-- Pintu Gelap -->
            <rect x="50" y="58" width="8" height="12" rx="2" fill="url(#glossy-dark)" filter="url(#inner-shadow)" />
            
            <!-- Atap Rumah Limasan -->
            <path d="M 34 50 L 54 30 L 74 50 Z" fill="#F59E0B" filter="url(#inner-shadow)" stroke="url(#glossy-white)" stroke-width="1.5" stroke-linejoin="round" />

        </g>
        
        <!-- Layer 4: Tipografi (Paling Atas) -->
        <text x="50" y="82" font-family="'Space Grotesk', sans-serif" font-weight="bold" font-size="11" letter-spacing="1" fill="#FFFFFF" text-anchor="middle" filter="url(#drop-shadow-sm)">DESAKU</text>
    </svg_elements>
    <visual_prompt>Ikon 'Desaku' memancarkan harmoni alam dan kehangatan desa melalui gradasi Emerald Green hingga Warm Amber. Komposisi ini menghindari warna monoton biru dengan menonjolkan atap limasan berwarna oranye berdimensi dan pepohonan hijau yang dipahat dengan material glossy-white serta inner-shadow yang presisi. Ditopang oleh latar frosted-glass bergaya visionOS, ikon ini terasa organik, modern, dan sangat premium (tanpa satupun menggunakan elemen flat/emoji).</visual_prompt>
</icon_design>
