<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>BacaGForm</app_name>
    <colors>
        <color_start>#8B5CF6</color_start> <!-- Vivid Purple -->
        <color_end>#10B981</color_end>   <!-- Emerald Green -->
    </colors>
    <background_style>
        <ornament>ios17_fluid_wave</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.82</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Latar Belakang / Framing -->
        <circle cx="50" cy="50" r="42" class="frosted-glass" filter="url(#drop-shadow-sm)" />
        
        <!-- Objek Utama Volumetrik 3D -->
        <g filter="url(#drop-shadow-sm)">
            <g filter="url(#inner-shadow)">
                <!-- Lembaran Kertas Form -->
                <rect x="26" y="20" width="48" height="60" rx="8" fill="url(#glossy-white)" />
                <!-- Baris Data (Rongga gelap) -->
                <rect x="36" y="32" width="28" height="4" rx="2" fill="url(#glossy-dark)" opacity="0.8" />
                <rect x="36" y="42" width="18" height="4" rx="2" fill="url(#glossy-dark)" opacity="0.8" />
                <rect x="36" y="52" width="24" height="4" rx="2" fill="url(#glossy-dark)" opacity="0.8" />
                
                <!-- Mata Analitik / AI Reader (Aksen Warna) -->
                <circle cx="50" cy="65" r="8" fill="#10B981" />
                <circle cx="50" cy="65" r="3" fill="#FFFFFF" />
            </g>
        </g>
        
        <!-- Tipografi (Paling Atas) -->
        <text x="50" y="88" font-family="'Space Grotesk', sans-serif" font-weight="bold" font-size="10" fill="#FFFFFF" text-anchor="middle" filter="url(#drop-shadow-sm)">G-FORM</text>
    </svg_elements>
    <visual_prompt>Desain ini merepresentasikan lembaran data/form (kertas putih 3D) yang sedang dipindai atau dibaca oleh "mata analitik" (aksen Emerald). Penggunaan kombinasi kontras Purple dan Emerald (menghindari biru standar) menonjolkan kesan "Ajaib/Pintar" dan "Segar" dalam mengolah data mentah menjadi wawasan siap saji yang mencerahkan.</visual_prompt>
</icon_design>
