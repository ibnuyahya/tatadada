<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>BacaGForm</app_name>
    <colors>
        <color_start>#FF9500</color_start> <!-- Apple Orange/Gold -->
        <color_end>#AF52DE</color_end>   <!-- Apple Purple -->
    </colors>
    <background_style>
        <ornament>ios17_fluid_wave</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.82</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Latar Belakang / Framing (Paling Bawah) -->
        <circle cx="50" cy="50" r="42" class="frosted-glass" filter="url(#drop-shadow-sm)" />
        
        <!-- Objek Utama Volumetrik 3D: Laporan yang Terbaca -->
        <g filter="url(#drop-shadow-sm)">
            <!-- Kertas / Dokumen Dasar (Resin Putih) -->
            <g filter="url(#inner-shadow)">
                <rect x="25" y="20" width="50" height="60" rx="8" fill="url(#glossy-white)" />
                
                <!-- Baris Data Eksekutif (Rongga Resin Gelap) -->
                <rect x="35" y="32" width="30" height="6" rx="3" fill="url(#glossy-dark)" />
                <rect x="35" y="44" width="20" height="6" rx="3" fill="url(#glossy-dark)" />
                
                <!-- Lensa Analitik (Melting into the paper) -->
                <circle cx="55" cy="58" r="14" fill="url(#glossy-dark)" />
                <circle cx="55" cy="58" r="6" fill="#FF9500" /> <!-- Aksen Mata AI Emas -->
                
                <!-- Chart Bar Kecil (Aksen Ungu) -->
                <rect x="35" y="56" width="6" height="12" rx="2" fill="#AF52DE" />
            </g>
        </g>
        
        <!-- Tipografi (Paling Atas) -->
        <text x="50" y="88" font-family="'Space Grotesk', sans-serif" font-size="9" font-weight="bold" fill="#FFFFFF" text-anchor="middle" filter="url(#drop-shadow-sm)">ANALYZER</text>
    </svg_elements>
    <visual_prompt>Desain ini memvisualisasikan selembar data (putih glossy) yang sedang "ditembus" oleh lensa analitik AI (rongga gelap dengan inti emas menyala). Kombinasi warna Oranye dan Ungu (menghindari biru standar) dipilih untuk merepresentasikan "Kreativitas Analitik" dan "Kedalaman Wawasan Eksekutif". Seluruh elemen dipahat tanpa garis (stroke), mengandalkan filter inner-shadow untuk menciptakan efek material resin yang menyatu (melting geometry).</visual_prompt>
</icon_design>
