<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>CapKin</app_name>
    <colors>
        <color_start>#10B981</color_start> <!-- Emerald Green -->
        <color_end>#0F766E</color_end> <!-- Deep Teal -->
    </colors>
    <background_style>
        <ornament>aurora</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.85</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Latar Belakang / Framing (Paling Bawah) -->
        <circle cx="50" cy="50" r="42" class="frosted-glass" filter="url(#drop-shadow-sm)" />
        
        <!-- Objek Utama Volumetrik 3D -->
        <g filter="url(#drop-shadow-sm)">
            <g filter="url(#inner-shadow)">
                <!-- Grafik Batang Volumetrik -->
                <rect x="25" y="45" width="12" height="30" rx="4" fill="url(#glossy-white)" />
                <rect x="44" y="30" width="12" height="45" rx="4" fill="url(#glossy-dark)" />
                <rect x="63" y="15" width="12" height="60" rx="4" fill="#10B981" />
                
                <!-- Elemen Lensa/Target Aksen -->
                <circle cx="69" cy="21" r="14" fill="url(#glossy-white)" opacity="0.9" />
                <circle cx="69" cy="21" r="6" fill="#0F766E" />
            </g>
        </g>
        
        <!-- Tipografi (Paling Atas) -->
        <text x="50" y="86" font-family="'Space Grotesk', sans-serif" font-size="11" font-weight="bold" fill="#FFFFFF" text-anchor="middle" filter="url(#drop-shadow-sm)">CAPKIN</text>
    </svg_elements>
    <visual_prompt>Ikon merepresentasikan "Capaian Kinerja" dengan visual grafik batang volumetrik yang menanjak naik, dipadukan dengan elemen bullseye/lensa di puncaknya. Menggunakan kombinasi gradasi Emerald dan Teal yang SANGAT BERAGAM (tidak biru) untuk merepresentasikan performa, kesuksesan terukur, dan pertumbuhan metrik hijau, dibalut dalam material glossy dan kaca frosted khas visionOS.</visual_prompt>
</icon_design>
