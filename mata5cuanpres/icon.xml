<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>MATA5CUANPRES</app_name>
    <colors>
        <color_start>#F7B733</color_start>
        <color_end>#FC4A1A</color_end>
    </colors>
    <background_style>
        <ornament>ios17_fluid_wave</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.82</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Latar Belakang / Framing (Paling Bawah) -->
        <circle cx="50" cy="50" r="42" class="frosted-glass" filter="url(#drop-shadow-sm)" />
        
        <!-- Objek Utama Volumetrik 3D: Mesin Kompresi Log (Compactor) -->
        <g filter="url(#drop-shadow-sm)">
            <g filter="url(#inner-shadow)">
                <!-- Base Panel Dokumen Log (Glossy White) -->
                <rect x="22" y="18" width="56" height="64" rx="14" fill="url(#glossy-white)" />
                
                <!-- Terminal Core / Ruang Data (Glossy Dark) -->
                <rect x="28" y="28" width="44" height="40" rx="8" fill="url(#glossy-dark)" />
                
                <!-- Garis Data Kompresi: Menyimbolkan data besar (Emas) dipres menjadi intisari kecil (Hijau) -->
                <rect x="34" y="36" width="32" height="5" rx="2.5" fill="#F7B733" filter="url(#inner-shadow)" />
                <rect x="34" y="45" width="22" height="5" rx="2.5" fill="#FC4A1A" filter="url(#inner-shadow)" />
                <rect x="34" y="54" width="12" height="5" rx="2.5" fill="#00F260" filter="url(#inner-shadow)" />
            </g>
        </g>
        
        <!-- Tipografi (Paling Atas) -->
        <text x="50" y="77" font-family="'Space Grotesk', sans-serif" font-size="11" font-weight="bold" fill="#FFFFFF" text-anchor="middle" filter="url(#drop-shadow-sm)">M5P</text>
    </svg_elements>
    <visual_prompt>Desain ini merepresentasikan mesin kompresi (Compactor) untuk data MetaTrader. Material frosted glass melingkar sebagai dasar ekosistem Apple/iOS 17. Di tengah terdapat log document dari glossy-white dengan rongga terminal layar (glossy-dark) yang memuat elemen bar data berwarna kontras (Emas, Oranye Api, dan Hijau Neon). Pola bar data yang semakin mengecil ke bawah memvisualisasikan algoritma kompresi 'lossy/lossless' (Pres) yang memadatkan ribuan baris menjadi intisari krusial (Cuan).</visual_prompt>
</icon_design>
