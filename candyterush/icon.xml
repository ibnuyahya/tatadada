<?xml version="1.0" encoding="UTF-8"?>
<icon_design>
    <app_name>CandyTerush</app_name>
    <colors>
        <color_start>#ec4899</color_start>
        <color_end>#8b5cf6</color_end>
    </colors>
    <background_style>
        <ornament>aurora</ornament>
    </background_style>
    <proportions>
        <icon_scale>0.85</icon_scale>
    </proportions>
    <svg_elements>
        <!-- Latar Belakang / Framing (Paling Bawah) -->
        <circle cx="50" cy="50" r="42" class="frosted-glass" filter="url(#drop-shadow-sm)" />
        
        <!-- Objek Utama Volumetrik 3D: Candy/Lollipop -->
        <g filter="url(#drop-shadow-sm)">
            <!-- Stick Lollipop -->
            <g filter="url(#inner-shadow)">
                <rect x="46" y="50" width="8" height="35" rx="4" fill="url(#glossy-white)" />
            </g>
            
            <!-- Candy Base -->
            <g filter="url(#inner-shadow)">
                <circle cx="50" cy="40" r="25" fill="#f472b6" />
                
                <!-- Swirl Ornaments -->
                <path d="M 50 15 a 25 25 0 0 1 25 25" fill="none" stroke="#fbcfe8" stroke-width="4" stroke-linecap="round" />
                <path d="M 25 40 a 25 25 0 0 1 25 -25" fill="none" stroke="#ffffff" stroke-width="6" stroke-linecap="round" />
                
                <!-- Highlight/Glossy reflection manual di atas permen -->
                <ellipse cx="38" cy="28" rx="8" ry="4" fill="url(#glossy-white)" transform="rotate(-30 38 28)" />
            </g>
        </g>
        
        <!-- Tipografi (Paling Atas) -->
        <text x="50" y="85" font-family="'Pacifico', cursive" font-size="12" fill="#FFFFFF" text-anchor="middle" filter="url(#drop-shadow-sm)">Candy</text>
    </svg_elements>
    <visual_prompt>Lollipop 3D yang sangat glossy (Candy) yang menggunakan gradasi Pink (#f472b6) dan highlight putih (#glossy-white) dengan ornamen pusaran gula. Latar belakang memakai aurora warna pink-ungu untuk nuansa yang manis dan menyenangkan. Cincin frosted glass memberi kesan Apple UI.</visual_prompt>
</icon_design>
